#!/usr/bin/env bash
#
# Pull the Gateway API standard channel CRDs from upstream and cache them in
# manifests/bundle.<version>.yaml so rendering is reproducible offline.
#
# Concurrency safety: each invocation downloads into its own unique mktemp
# directory, then atomically renames the finished bundle into place (rename
# is an atomic system call on posix filesystems).  The EXIT trap removes the
# temporary directory on failure so no partial files are left behind.
#
# Integrity: upstream tags are mutable refs and the download is not checksum
# pinned.  This is mitigated because the cached bundle and the rendered
# deploy files are committed to git, so any change in fetched content is
# visible in review before it can take effect.

set -euo pipefail

cd "$(dirname "$0")"
mkdir -p manifests
version="${1:-}"
if [[ -z "${version}" ]]; then
  echo "error: no version passed as arg 1" >&2
  echo "see versions at https://github.com/kubernetes-sigs/gateway-api/releases" >&2
  exit 1
fi
# Guard against path traversal: version is interpolated into both the bundle
# path and the download URL, so a value containing / would escape manifests/.
if [[ "${version}" == */* ]]; then
  echo "error: version must not contain '/': ${version}" >&2
  exit 1
fi

bundle="manifests/bundle.${version}.yaml"

if ! [[ -s "$bundle" ]]; then
  tmpdir="$(mktemp -d manifests/.tmp.XXXXXX)"
  trap 'rm -rf "$tmpdir"' EXIT

  # Standard channel CRDs only.  Experimental channel resources (e.g.
  # tlsroutes) are deliberately excluded.
  for x in gatewayclasses gateways httproutes referencegrants grpcroutes; do
    # --fail aborts on HTTP errors so an error body is never cached.
    curl -fsSL --retry 3 -o "${tmpdir}/${x}.yaml" \
      "https://raw.githubusercontent.com/kubernetes-sigs/gateway-api/v${version}/config/crd/standard/gateway.networking.k8s.io_${x}.yaml"
    # The leading newline guards against an upstream file missing its
    # trailing newline, which would otherwise merge the separator onto the
    # previous line.  A blank line before --- is harmless YAML.
    printf '\n---\n' >> "${tmpdir}/bundle.yaml"
    cat "${tmpdir}/${x}.yaml" >> "${tmpdir}/bundle.yaml"
    echo "appended: $x to ${tmpdir}/bundle.yaml" >&2
  done

  # rename is guaranteed atomic system call on posix filesystems
  mv -f "${tmpdir}/bundle.yaml" "$bundle"
  echo "cached: $bundle" >&2
fi

cat "$bundle"
