#!/usr/bin/env bash
#
# Pull the Keycloak operator install manifest (kubernetes.yml — the operator
# Deployment, ServiceAccount, and RBAC; the CRDs are separate upstream files
# fetched by the sibling operator-crds component) from the upstream
# keycloak-k8s-resources tag and cache it in manifests/bundle.<version>.yaml
# so rendering is reproducible offline.
#
# Concurrency safety: each invocation downloads into its own unique mktemp
# directory, then atomically renames the finished bundle into place (rename
# is an atomic system call on posix filesystems).  The EXIT trap removes the
# temporary directory on failure so no partial files are left behind.
#
# Integrity: upstream release assets are not checksum pinned here.  This is
# mitigated because the cached bundle and the rendered deploy files are
# committed to git, so any change in fetched content is visible in review
# before it can take effect.

set -euo pipefail

cd "$(dirname "$0")"
mkdir -p manifests
version="${1:-}"
if [[ -z "${version}" ]]; then
  echo "error: no version passed as arg 1" >&2
  echo "see versions at https://github.com/keycloak/keycloak-k8s-resources/tags" >&2
  exit 1
fi
# Allowlist the version format before interpolating it into the bundle path
# and the download URL: a single check rejects path separators, URL
# metacharacters, whitespace, and control characters.
if ! [[ "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  printf 'error: version must look like 26.6.3 (got %q)\n' "${version}" >&2
  exit 1
fi

bundle="manifests/bundle.${version}.yaml"

if ! [[ -s "$bundle" ]]; then
  tmpdir="$(mktemp -d manifests/.tmp.XXXXXX)"
  trap 'rm -rf "$tmpdir"' EXIT

  # --fail aborts on HTTP errors so an error body is never cached.
  curl -fsSL --retry 3 -o "${tmpdir}/bundle.yaml" \
    "https://raw.githubusercontent.com/keycloak/keycloak-k8s-resources/${version}/kubernetes/kubernetes.yml"
  # curl --fail does not catch an empty 200 body; never cache one.
  if ! [[ -s "${tmpdir}/bundle.yaml" ]]; then
    echo "error: empty download: kubernetes.yml" >&2
    exit 1
  fi

  # rename is guaranteed atomic system call on posix filesystems
  mv -f "${tmpdir}/bundle.yaml" "$bundle"
  echo "cached: $bundle" >&2
fi

cat "$bundle"
