# Makefile.controller — isolated targets for the holos-controller service
# (ADR-18, HOL-1309). Included from the root Makefile.
#
# Every target here is namespaced controller-* so it never collides with the
# existing holos-paas targets (build, test, docker-build, publish, ...) and does
# not touch scripts/apply, scripts/render, or scripts/publish. controller-gen
# and kustomize are pinned and installed under bin/, the standard kubebuilder
# convention, so generation is reproducible without a system-wide install.

# Container image coordinates for the controller. Defaults target the local k3d
# in-cluster registry so a pushed image is pullable by the cluster (mirrors the
# holos-paas IMAGE_* defaults in the root Makefile).
CONTROLLER_IMAGE_REPO ?= quay.holos.localhost/holos/holos-controller
CONTROLLER_IMAGE_TAG  ?= dev
CONTROLLER_IMAGE      ?= $(CONTROLLER_IMAGE_REPO):$(CONTROLLER_IMAGE_TAG)
CONTROLLER_PLATFORM   ?= linux/arm64

# Multi-arch (manifest list) platforms for the controller image. The buildx
# builder itself is the shared $(BUILDX_BUILDER) defined in the root Makefile
# before the include: both services cross-compile identically, so they
# intentionally share one docker-container builder rather than each bootstrapping
# its own. controller-docker-buildx-builder below is deliberately equivalent to
# the root docker-buildx-builder target.
CONTROLLER_MULTIARCH_PLATFORMS ?= linux/amd64,linux/arm64

# Pinned tool versions and locations. bin/ is gitignored (root .gitignore /bin/).
LOCALBIN ?= $(CURDIR)/bin
CONTROLLER_GEN ?= $(LOCALBIN)/controller-gen
KUSTOMIZE      ?= $(LOCALBIN)/kustomize
ENVTEST        ?= $(LOCALBIN)/setup-envtest
CONTROLLER_GEN_VERSION ?= v0.20.1
KUSTOMIZE_VERSION      ?= v5.6.0
# setup-envtest is versioned by the controller-runtime branch it ships with.
# Pin to the release-0.21 branch so it matches the controller-runtime v0.21.0
# dependency and builds with the module's Go toolchain (newer setup-envtest tags
# require a newer Go than go.mod declares).
ENVTEST_VERSION        ?= release-0.21
# Kubernetes API server / etcd binaries setup-envtest provisions for the
# envtest-based reconciler tests. Pin the version to keep test runs reproducible.
ENVTEST_K8S_VERSION    ?= 1.33.0

# CRD generation options: shared across deepcopy + manifests.
CRD_OPTIONS ?= crd:generateEmbeddedObjectMeta=true

$(LOCALBIN):
	mkdir -p $(LOCALBIN)

# The tool targets are .PHONY (not file targets) so the version check runs on
# every invocation: a file target named $(CONTROLLER_GEN) would be considered
# up to date whenever bin/controller-gen exists — even at the wrong version —
# and Make would never re-run the check. As phony recipes they always compare
# the installed version against the pin and reinstall on mismatch.
.PHONY: controller-gen-tool
controller-gen-tool: | $(LOCALBIN) ## Install controller-gen under bin/ at the pinned version.
	@test -x $(CONTROLLER_GEN) && [ "$$($(CONTROLLER_GEN) --version 2>/dev/null | awk '{print $$2}')" = "$(CONTROLLER_GEN_VERSION)" ] || \
		GOBIN=$(LOCALBIN) go install sigs.k8s.io/controller-tools/cmd/controller-gen@$(CONTROLLER_GEN_VERSION)

.PHONY: kustomize-tool
kustomize-tool: | $(LOCALBIN) ## Install kustomize under bin/ at the pinned version.
	@test -x $(KUSTOMIZE) && [ "v$$($(KUSTOMIZE) version 2>/dev/null | sed -E 's/^v?([0-9.]+).*/\1/')" = "$(KUSTOMIZE_VERSION)" ] || \
		GOBIN=$(LOCALBIN) go install sigs.k8s.io/kustomize/kustomize/v5@$(KUSTOMIZE_VERSION)

.PHONY: envtest-tool
envtest-tool: | $(LOCALBIN) ## Install setup-envtest under bin/ (version follows controller-runtime).
	@test -x $(ENVTEST) || GOBIN=$(LOCALBIN) go install sigs.k8s.io/controller-runtime/tools/setup-envtest@$(ENVTEST_VERSION)

.PHONY: controller-generate
controller-generate: controller-gen-tool ## Generate deepcopy methods (zz_generated.deepcopy.go).
	$(CONTROLLER_GEN) object:headerFile="hack/boilerplate.go.txt" paths="./api/..."

.PHONY: controller-manifests
controller-manifests: controller-gen-tool ## Generate CRD manifests and RBAC under config/.
	$(CONTROLLER_GEN) $(CRD_OPTIONS) rbac:roleName=holos-controller-manager-role \
		paths="./api/..." paths="./cmd/holos-controller/..." paths="./internal/controller/..." \
		output:crd:artifacts:config=config/crd/bases \
		output:rbac:artifacts:config=config/rbac

# controller-manifests-build renders the full config/default kustomize tree to
# stdout (CRDs, ServiceAccount, ClusterRole/Binding, leader-election RBAC, the
# manager Deployment, and the metrics Service — all targeting holos-controller,
# with the manager image set by config/manager's images transformer). It is the
# read-only render/inspect entrypoint, convenient for diffing or golden-checking
# the rendered install. It applies nothing and mutates no committed file: the
# image override (for a non-default CONTROLLER_IMAGE) belongs to controller-deploy.
.PHONY: controller-manifests-build
controller-manifests-build: kustomize-tool ## Render config/default to stdout (no apply).
	$(KUSTOMIZE) build config/default

# The controller-{install,deploy,undeploy} targets are the isolated deploy
# entrypoints (AC #6). They wrap kubectl apply/delete -k against the config/
# kustomize tree and deliberately never invoke scripts/apply, scripts/render, or
# any holos-paas target — the holos-controller install is managed independently
# of the Holos-rendered platform (the Namespace it targets is the one exception,
# owned centrally by holos/namespaces.cue and applied by the platform).
#
# controller-install applies only the CRDs (config/crd), so the API group is
# registered before any custom resource or the manager that watches them.
.PHONY: controller-install
controller-install: kustomize-tool ## Install the quay.holos.run CRDs into the cluster.
	$(KUSTOMIZE) build config/crd | kubectl apply --server-side -f -

# controller-deploy applies the full install (CRDs + RBAC + manager + metrics
# Service) with the manager image set to $(CONTROLLER_IMAGE). The holos-controller
# Namespace must already exist (the platform's namespaces component creates it);
# this tree only targets it.
#
# When CONTROLLER_IMAGE is overridden from the committed default, the image is
# substituted via a kustomize edit and the exact prior bytes of
# config/manager/kustomization.yaml are restored afterward from a temp copy — NOT
# `git checkout`, which would clobber any pre-existing uncommitted edits to that
# file. The backup/restore round-trips the file to whatever it was before this
# target ran (committed or not). The committed default already matches the
# no-override case, so a plain `make controller-deploy` makes no edit at all.
.PHONY: controller-deploy
controller-deploy: kustomize-tool ## Deploy the controller (CRDs, RBAC, manager, metrics Service).
	@set -e; \
	if [ "$(CONTROLLER_IMAGE)" != "$(CONTROLLER_IMAGE_REPO):$(CONTROLLER_IMAGE_TAG)" ]; then \
		backup="$$(mktemp)"; \
		cp config/manager/kustomization.yaml "$$backup"; \
		trap 'cp "$$backup" config/manager/kustomization.yaml; rm -f "$$backup"' EXIT; \
		( cd config/manager && $(KUSTOMIZE) edit set image controller=$(CONTROLLER_IMAGE) ); \
	fi; \
	$(KUSTOMIZE) build config/default | kubectl apply --server-side -f -

# controller-undeploy removes the full install. --ignore-not-found keeps it
# idempotent. It does NOT delete the holos-controller Namespace (owned centrally
# by the platform), only the resources this tree installs into it plus the
# cluster-scoped CRDs and ClusterRole/Binding.
.PHONY: controller-undeploy
controller-undeploy: kustomize-tool ## Remove the controller install (keeps the namespace).
	$(KUSTOMIZE) build config/default | kubectl delete --ignore-not-found -f -

.PHONY: controller-fmt
controller-fmt: ## Run go fmt against the controller, API, and internal sources.
	go fmt ./cmd/holos-controller/... ./api/... ./internal/quay/... ./internal/controller/...

.PHONY: controller-vet
controller-vet: ## Run go vet against the controller, API, and internal sources.
	go vet ./cmd/holos-controller/... ./api/... ./internal/quay/... ./internal/controller/...

.PHONY: controller-build
controller-build: controller-fmt controller-vet ## Build the holos-controller binary.
	go build -o bin/holos-controller ./cmd/holos-controller

# controller-test provisions the envtest control-plane binaries (kube-apiserver +
# etcd) via setup-envtest and exports KUBEBUILDER_ASSETS so the envtest-based
# reconciler tests under internal/controller can stand up a real API server. The
# api/, cmd/, and internal/quay packages have no such dependency but run in the
# same invocation for a single test entrypoint.
.PHONY: controller-test
controller-test: controller-fmt controller-vet envtest-tool ## Run controller, API, and Quay client tests with the race detector.
	@set -e; \
	assets="$$($(ENVTEST) use $(ENVTEST_K8S_VERSION) --bin-dir $(LOCALBIN) -p path)"; \
	if [ -z "$$assets" ] || [ ! -x "$$assets/etcd" ]; then \
		echo "ERROR: setup-envtest did not provision control-plane binaries (KUBEBUILDER_ASSETS would be empty); the envtest reconciler tests would silently skip." >&2; \
		exit 1; \
	fi; \
	KUBEBUILDER_ASSETS="$$assets" \
		go test -race ./api/... ./cmd/holos-controller/... ./internal/quay/... ./internal/controller/...

# Image targets use buildx so the builder stage runs on the native host and the
# Go toolchain cross-compiles to $(CONTROLLER_PLATFORM) — mirrors the holos-paas
# docker-build/docker-push pattern but with the controller Dockerfile.
.PHONY: controller-docker-build
controller-docker-build: ## Build the controller image for $(CONTROLLER_PLATFORM) tagged $(CONTROLLER_IMAGE).
	docker buildx build --platform $(CONTROLLER_PLATFORM) -f Dockerfile.controller -t $(CONTROLLER_IMAGE) --load .

.PHONY: controller-docker-push
controller-docker-push: ## Build for $(CONTROLLER_PLATFORM) and push $(CONTROLLER_IMAGE) to the registry.
	docker buildx build --platform $(CONTROLLER_PLATFORM) -f Dockerfile.controller -t $(CONTROLLER_IMAGE) --push .

# Multi-arch controller image index. Mirrors the root docker-buildx pair: the
# builder bootstrap is intentionally equivalent to (and reuses the same
# $(BUILDX_BUILDER) as) the root docker-buildx-builder target, since both
# services produce identical cross-compiled output from a docker-container
# builder. No QEMU is required — Dockerfile.controller pins the builder stage to
# $BUILDPLATFORM and cross-compiles via the Go toolchain.
.PHONY: controller-docker-buildx-builder
controller-docker-buildx-builder: ## Ensure the shared docker-container buildx builder $(BUILDX_BUILDER) exists.
	docker buildx inspect $(BUILDX_BUILDER) >/dev/null 2>&1 || \
		docker buildx create --name $(BUILDX_BUILDER) --driver docker-container

# Push-only: a multi-platform build cannot --load into the local Docker daemon,
# so this emits the manifest list straight to $(CONTROLLER_IMAGE). Verify with:
#   docker buildx imagetools inspect $(CONTROLLER_IMAGE)
.PHONY: controller-docker-buildx
controller-docker-buildx: controller-docker-buildx-builder ## Build and push the multi-arch $(CONTROLLER_MULTIARCH_PLATFORMS) image index $(CONTROLLER_IMAGE).
	docker buildx build --builder $(BUILDX_BUILDER) --platform $(CONTROLLER_MULTIARCH_PLATFORMS) -f Dockerfile.controller -t $(CONTROLLER_IMAGE) --push .
