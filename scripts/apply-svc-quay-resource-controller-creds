#!/usr/bin/env bash

# Create the Quay superuser credential Secret the holos-controller reads.
#
# The script keeps its historical name (it provisions the credential that acts
# as the svc-quay-resource-controller Keycloak superuser identity), but it now
# produces the Secret the controller's credential resolver actually reads
# (HOL-1313): holos-controller-quay-creds in the holos-controller namespace,
# with keys url + token (+ optional username), matching
# internal/controller/quay/credentials.go.
#
# The token is still minted by hand per
# docs/runbooks/quay-resource-controller-credentials.md and never committed —
# this helper only applies the operator-supplied value as a Secret's material at
# runtime (the Runtime Secret Handling guardrail).

set -euo pipefail

cat <<'EOF'
╔═══════════════════════════════════════════════════════════════════════╗
║         Quay OAuth Application Token Setup                            ║
║                                                                       ║
║  This script creates the holos-controller-quay-creds Secret in the    ║
║  holos-controller namespace from a Quay OAuth Application token for    ║
║  the svc-quay-resource-controller service account.                    ║
╚═══════════════════════════════════════════════════════════════════════╝

INSTRUCTIONS:

1. Navigate to: https://quay.holos.internal/organization/platform-automation?tab=OAuthApplications

2. Log in as the svc-quay-resource-controller Keycloak user

3. If the platform-automation organization does not exist, create it:
   - Click "Create Organization"
   - Name: platform-automation

4. Create an OAuth Application with the following settings:
   - Application Name: svc-quay-resource-controller
   - Redirect URI: http://localhost:8080/callback (or leave blank if not needed)

5. Generate an Access Token with these scopes:
   - org:admin
   - repo:admin
   - repo:create
   - repo:read
   - repo:write
   - super:user
   - user:admin
   - user:read

6. Copy the generated Access Token and paste it below when prompted.

EOF

read -r -p "Press ENTER when you have the Access Token ready..."

echo ""
read -r -sp "Paste the Access Token: " TOKEN
echo ""

if [ -z "$TOKEN" ]; then
    echo "ERROR: Access Token cannot be empty" >&2
    exit 1
fi

# The Quay API base URL the controller's credential resolver reads from the
# Secret's url key. Override QUAY_URL for a non-default Quay endpoint.
QUAY_URL="${QUAY_URL:-https://quay.holos.internal}"

NAMESPACE="holos-controller"
SECRET_NAME="holos-controller-quay-creds"

echo "Creating secret $SECRET_NAME in $NAMESPACE namespace..."

# Keys url + token + username match the controller's credential resolver
# (internal/controller/quay/credentials.go): url and token are required;
# username is informational (the identity the token acts as).
kubectl create secret generic "$SECRET_NAME" \
    --namespace="$NAMESPACE" \
    --from-literal=url="$QUAY_URL" \
    --from-literal=token="$TOKEN" \
    --from-literal=username=svc-quay-resource-controller \
    --dry-run=client -o yaml | kubectl apply -f -

echo "✓ Secret '$SECRET_NAME' created in '$NAMESPACE' namespace"
echo ""
echo "Verifying secret..."
kubectl get secret "$SECRET_NAME" -n "$NAMESPACE"

echo ""
echo "✓ Done!"
