#!/usr/bin/env bash
# Generate Go from the .proto sources and verify the committed tree is
# diff-clean (ADR-14).
#
# Re-runs `buf generate` and fails if anything under internal/gen/ is modified,
# deleted, or untracked afterward. The .proto under proto/ is the single source
# of truth; the Go under internal/gen/ is a build output that must always match
# what buf renders from it. A non-empty status after regeneration means the
# committed generated tree is stale — the .proto changed without `make generate`
# being run and the result committed. This mirrors scripts/render's diff-clean
# check for rendered manifests.
#
# Usable locally and by CI:
#   - Locally: edit the .proto, run `make generate` (or this script), and commit
#     the .proto change and the regenerated internal/gen/ tree together; a clean
#     exit confirms the committed tree matches the .proto.
#   - CI: run on a fresh checkout; any diff fails the build.
#
# Prerequisites:
#   - buf  (https://buf.build/docs/installation)
#   - git
#
# NOTE: prerequisite checks are inline rather than a copy of the check_prereq
# helper shared verbatim by scripts/local-{ca,dns,k3d} — their NOTE blocks call
# for consolidating into a shared helper only if a fourth copy appears, and
# scripts/render likewise keeps its checks inline, so this script does the same.

set -euo pipefail

# Resolve the repo root so this script works from any working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if ! command -v buf >/dev/null 2>&1; then
  echo "ERROR: 'buf' not found on PATH." >&2
  echo "       Install from https://buf.build/docs/installation" >&2
  exit 1
fi
if ! command -v git >/dev/null 2>&1; then
  echo "ERROR: 'git' not found on PATH." >&2
  exit 1
fi

echo "Generating Go from proto sources in ${REPO_ROOT} ..."
(cd "${REPO_ROOT}" && buf generate)

# Fail when generation left modified or deleted tracked files, or new untracked
# files, under internal/gen/. git status --porcelain covers all three.
# --untracked-files=all overrides any status.showUntrackedFiles=no in the user's
# git config, which would otherwise hide a newly generated, uncommitted file.
STATUS="$(git -C "${REPO_ROOT}" status --porcelain --untracked-files=all -- internal/gen)"
if [[ -n "${STATUS}" ]]; then
  echo "ERROR: internal/gen/ has uncommitted changes after buf generate:" >&2
  echo "${STATUS}" >&2
  # The diff is empty when the status is untracked-files-only; print it only
  # when tracked files changed. --no-ext-diff keeps the output deterministic
  # regardless of any diff.external in the user's git config.
  if ! git -C "${REPO_ROOT}" diff --quiet -- internal/gen; then
    git -C "${REPO_ROOT}" --no-pager diff --no-ext-diff -- internal/gen >&2
  fi
  echo "ERROR: commit the .proto change and the regenerated internal/gen tree" >&2
  echo "       together (run 'make generate')." >&2
  exit 1
fi

echo "Generated code is diff-clean."
