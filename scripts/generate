#!/usr/bin/env bash
# Generate Go from the .proto sources and verify the committed tree is
# diff-clean (ADR-14).
#
# Removes internal/gen/, re-runs `buf generate`, and fails if anything under
# internal/gen/ is modified, deleted, or untracked afterward. The .proto under
# proto/ is the single source of truth; the Go under internal/gen/ is a build
# output that must always match what buf renders from it. Removing the generated
# tree first makes orphans detectable: `buf generate` never prunes a `.pb.go`
# whose `.proto` was renamed or removed, so a stale generated file would
# otherwise linger with a clean status and silently defeat the source-of-truth
# guarantee. After this script internal/gen/ exactly matches what the .proto
# renders — a non-empty status means the committed tree is stale or orphaned.
# This mirrors scripts/render's diff-clean check for rendered manifests.
#
# Usable locally and by CI:
#   - Locally: edit the .proto, run `make generate` (or this script), and commit
#     the .proto change and the regenerated internal/gen/ tree together; a clean
#     exit confirms the committed tree matches the .proto.
#   - CI: run on a fresh checkout; any diff fails the build.
#
# Prerequisites:
#   - buf  (https://buf.build/docs/installation)
#   - git
#
# NOTE: prerequisite checks are inline rather than a copy of the check_prereq
# helper shared verbatim by scripts/local-{ca,dns,k3d} — their NOTE blocks call
# for consolidating into a shared helper only if a fourth copy appears, and
# scripts/render likewise keeps its checks inline, so this script does the same.

set -euo pipefail

# Resolve the repo root so this script works from any working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if ! command -v buf >/dev/null 2>&1; then
  echo "ERROR: 'buf' not found on PATH." >&2
  echo "       Install from https://buf.build/docs/installation" >&2
  exit 1
fi
if ! command -v git >/dev/null 2>&1; then
  echo "ERROR: 'git' not found on PATH." >&2
  exit 1
fi

# Require a clean internal/gen/ tree before touching anything: the generated
# tree is removed below, so an uncommitted change or untracked file under
# internal/gen/ must fail here, before it could be silently deleted, rather than
# after. --untracked-files=all overrides any status.showUntrackedFiles=no in the
# user's git config, which would otherwise hide untracked files from this guard.
STATUS="$(git -C "${REPO_ROOT}" status --porcelain --untracked-files=all -- internal/gen)"
if [[ -n "${STATUS}" ]]; then
  echo "ERROR: internal/gen/ has uncommitted changes; commit or stash them first:" >&2
  echo "${STATUS}" >&2
  exit 1
fi

# If the generation fails or is interrupted after the generated tree was
# removed, restore the committed tree and remove partial output so the next run
# starts from the precondition-clean state. GENERATE_OK guards the EXIT trap:
# once generation succeeds, a drift failure below must leave the tree as-is for
# inspection, not restore it. The INT/TERM traps convert signals into a normal
# exit so the EXIT trap reliably runs (bash does not run EXIT traps on untrapped
# fatal signals) while preserving the conventional 128+signal exit codes.
# Installed before the rm -rf so the generated tree is never removed without the
# restore path armed.
GENERATE_OK=""
restore_gen() {
  if [[ -z "${GENERATE_OK}" ]]; then
    git -C "${REPO_ROOT}" restore -- internal/gen || true
    git -C "${REPO_ROOT}" clean -qfd -- internal/gen || true
  fi
}
trap restore_gen EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

# Remove the committed generated tree before generating so files buf no longer
# writes (orphans from a renamed or removed .proto) surface as deletions in the
# status check below.
rm -rf "${REPO_ROOT}/internal/gen"

echo "Generating Go from proto sources in ${REPO_ROOT} ..."
(cd "${REPO_ROOT}" && buf generate)

# Generation succeeded; on drift below we want the tree left as-is for
# inspection, not restored.
GENERATE_OK=1

# Fail when generation left modified or deleted tracked files, or new untracked
# files, under internal/gen/. git status --porcelain covers all three.
# --untracked-files=all overrides any status.showUntrackedFiles=no in the user's
# git config, which would otherwise hide a newly generated, uncommitted file.
STATUS="$(git -C "${REPO_ROOT}" status --porcelain --untracked-files=all -- internal/gen)"
if [[ -n "${STATUS}" ]]; then
  echo "ERROR: internal/gen/ has uncommitted changes after buf generate:" >&2
  echo "${STATUS}" >&2
  # The diff is empty when the status is untracked-files-only; print it only
  # when tracked files changed. --no-ext-diff keeps the output deterministic
  # regardless of any diff.external in the user's git config.
  if ! git -C "${REPO_ROOT}" diff --quiet -- internal/gen; then
    git -C "${REPO_ROOT}" --no-pager diff --no-ext-diff -- internal/gen >&2
  fi
  echo "ERROR: commit the .proto change and the regenerated internal/gen tree" >&2
  echo "       together (run 'make generate')." >&2
  exit 1
fi

echo "Generated code is diff-clean."
