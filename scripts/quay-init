#!/usr/bin/env bash
# Bootstrap the Quay registry deployed by the quay component: create the
# initial admin user, the holos organization, and an organization robot
# account (holos+robot) that can push to not-yet-existing repositories
# under the holos org (a team with the creator role auto-creates
# repositories on push).
#
# Run this once after `scripts/apply` brings the quay Deployment up.  The
# script is idempotent: every step is check-then-create, so a second run
# against an already-initialized registry exits 0 without changing state.
#
# No credentials are committed to the repository — everything is generated
# here at bootstrap and stored in Secrets in the quay namespace, mirroring
# how the Keycloak operator generates keycloak-initial-admin:
#
#   quay-initial-admin  keys username/password/token — the admin user and
#                       the OAuth access token returned by the one-shot
#                       /api/v1/user/initialize endpoint (the token is what
#                       authorizes re-runs of this script; Quay OAuth
#                       tokens do not expire)
#   quay-robot-pull     kubernetes.io/dockerconfigjson built from the
#                       robot token, for later in-cluster pull consumers
#
# Retrieve credentials the same way as Keycloak's:
#   kubectl -n quay get secret quay-initial-admin -o json \
#     | jq '.data | map_values(@base64d)'
#
# The /api/v1/user/initialize endpoint only works while the registry
# database has no users and the quay component's config sets
# FEATURE_USER_INITIALIZE: true (it does — see
# holos/components/quay/buildplan.cue).  If the registry was initialized
# outside this script there is no API credential to recover, so the script
# fails with guidance rather than guessing.
#
# Known crash window: if the initialize call succeeds but the Secret write
# that immediately follows fails, the admin credentials are lost (the
# endpoint is one-shot).  Recovery is a registry reset — for the local
# cluster, delete the quay database contents and the quay-* bootstrap
# Secrets, or simply reset the cluster (docs/local-cluster.md).
#
# Environment overrides:
#   KUBE_CONTEXT — kubectl context for the Secret reads/writes (default:
#                  the current context).  The API base URL is pinned to
#                  https://quay.holos.localhost — the hostname the quay
#                  component serves — so this script only ever targets the
#                  local registry regardless of context.
#
# Prerequisites:
#   - curl, jq
#   - kubectl, with a context pointing at the cluster running Quay
#
# NOTE: prerequisite checks are inline rather than a copy of the
# check_prereq helper shared verbatim by scripts/local-{ca,dns,k3d} — their
# NOTE blocks call for consolidating into a shared helper if a fourth copy
# appears, so this script (like scripts/apply) deliberately avoids creating
# one.

set -euo pipefail

QUAY_URL="https://quay.holos.localhost"
NAMESPACE="quay"
ADMIN_SECRET="quay-initial-admin"
PULL_SECRET="quay-robot-pull"
ADMIN_USER="admin"
ADMIN_EMAIL="admin@holos.localhost"
ORG="holos"
ORG_EMAIL="org+holos@holos.localhost"
ROBOT_SHORTNAME="robot"
ROBOT="${ORG}+${ROBOT_SHORTNAME}"
TEAM="creators"

for cmd in curl jq kubectl; do
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "ERROR: '${cmd}' not found on PATH." >&2
    exit 1
  fi
done

KUBE_CONTEXT="${KUBE_CONTEXT:-$(kubectl config current-context)}"
echo "Will read/write Secrets via kubectl context: ${KUBE_CONTEXT}"
echo "Quay API: ${QUAY_URL}"

tmpdir="$(mktemp -d)"
finish() {
  [[ -d "$tmpdir" ]] && rm -rf "$tmpdir"
}
# A single EXIT trap is preferred over trapping ERR+INT+TERM: bash runs the
# EXIT trap exactly once on every termination path (normal exit, set -e
# failure, or a fatal SIGINT/SIGTERM), whereas combining EXIT with
# ERR/INT/TERM traps would run finish twice on error or interrupt.
trap finish EXIT

# Every file staged under tmpdir may carry credentials (request bodies,
# API responses, Secret manifests, the curl auth config), so pre-create
# each at mode 0600 before writing — the same install-then-write pattern
# as scripts/local-ca, avoiding a umask-governed window where secret
# material is world-readable.
install -m 0600 /dev/null "${tmpdir}/response"
install -m 0600 /dev/null "${tmpdir}/request.json"
install -m 0600 /dev/null "${tmpdir}/auth.curlrc"
install -m 0600 /dev/null "${tmpdir}/secret.yaml"

# --- helpers ------------------------------------------------------------------

# http METHOD PATH [REQUEST_BODY_FILE]
# Calls the Quay API; sets HTTP_STATUS (numeric code) and leaves the
# response body in ${tmpdir}/response.  Sends the admin OAuth token when
# auth.curlrc has been populated (the token rides in a 0600 curl config
# file, not a command-line argument, so it never appears in the process
# list).  Transport failures abort via set -e; HTTP error statuses do not
# (no -f), so callers branch on HTTP_STATUS.
http() {
  local method="$1" path="$2" body_file="${3:-}"
  local args=(-sS --max-time 30 -o "${tmpdir}/response" -w '%{http_code}'
    -X "${method}")
  if [[ -s "${tmpdir}/auth.curlrc" ]]; then
    args+=(--config "${tmpdir}/auth.curlrc")
  fi
  if [[ -n "${body_file}" ]]; then
    args+=(-H 'Content-Type: application/json' --data "@${body_file}")
  fi
  HTTP_STATUS="$(curl "${args[@]}" "${QUAY_URL}${path}")"
}

# base64 | tr -d '\n' is the portable approach: BSD base64 (macOS) wraps at
# 60 chars and GNU base64 (Linux) wraps at 76 chars — neither supports the
# other's no-wrap flag (-b 0 vs -w 0), so stripping newlines with tr is
# required for cross-platform use.
b64() {
  printf '%s' "$1" | base64 | tr -d '\n'
}

# apply_secret NAME TYPE KEY=VALUE...
# Server-side-applies a Secret manifest staged at mode 0600.  Server-side
# apply converges, so re-running with unchanged values is a no-op and a
# rotated value (e.g. a regenerated robot token) updates in place.
apply_secret() {
  local name="$1" type="$2" kv key value
  shift 2
  cat > "${tmpdir}/secret.yaml" <<EOF
apiVersion: v1
kind: Secret
metadata:
  name: ${name}
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/managed-by: quay-init
type: ${type}
data:
EOF
  for kv in "$@"; do
    key="${kv%%=*}"
    value="${kv#*=}"
    printf '  %s: %s\n' "${key}" "$(b64 "${value}")" >> "${tmpdir}/secret.yaml"
  done
  kubectl apply --context "${KUBE_CONTEXT}" --server-side=true \
    -f "${tmpdir}/secret.yaml"
}

# --- preflight ----------------------------------------------------------------

if ! curl -fsS --max-time 10 -o /dev/null "${QUAY_URL}/health/instance"; then
  echo "ERROR: Quay is not answering at ${QUAY_URL}/health/instance." >&2
  echo "       Run scripts/apply first (see docs/local-cluster.md)." >&2
  exit 1
fi

# --- step 1: initial admin user and API token ---------------------------------

# 16 random bytes hex-encoded: deterministic 32-char length, no SIGPIPE
# hazard under pipefail (head reads a fixed count and exits cleanly).
gen_password() {
  head -c 16 /dev/urandom | od -An -tx1 | tr -d ' \n'
}

if kubectl get secret "${ADMIN_SECRET}" --context "${KUBE_CONTEXT}" \
  --namespace "${NAMESPACE}" -o name >/dev/null 2>&1; then
  echo "Secret ${ADMIN_SECRET} exists; reusing stored admin credentials."
  TOKEN="$(kubectl get secret "${ADMIN_SECRET}" --context "${KUBE_CONTEXT}" \
    --namespace "${NAMESPACE}" -o jsonpath='{.data.token}' | base64 -d)"
  if [[ -z "${TOKEN}" ]]; then
    echo "ERROR: Secret ${ADMIN_SECRET} has no 'token' key; cannot call the API." >&2
    echo "       Delete the Secret and reset the registry to re-bootstrap." >&2
    exit 1
  fi
  printf 'header = "Authorization: Bearer %s"\n' "${TOKEN}" > "${tmpdir}/auth.curlrc"
  http GET /api/v1/user/
  if [[ "${HTTP_STATUS}" != 200 ]]; then
    echo "ERROR: stored admin token was rejected (HTTP ${HTTP_STATUS})." >&2
    echo "       Quay OAuth tokens do not expire, so the registry state and the" >&2
    echo "       ${ADMIN_SECRET} Secret have diverged (e.g. the quay database was" >&2
    echo "       reset without deleting the Secret).  Delete the Secret and the" >&2
    echo "       registry state, then re-run this script." >&2
    exit 1
  fi
else
  echo "Initializing the first user '${ADMIN_USER}' (one-shot endpoint)..."
  ADMIN_PASS="$(gen_password)"
  jq -n --arg u "${ADMIN_USER}" --arg p "${ADMIN_PASS}" --arg e "${ADMIN_EMAIL}" \
    '{username: $u, password: $p, email: $e, access_token: true}' \
    > "${tmpdir}/request.json"
  http POST /api/v1/user/initialize "${tmpdir}/request.json"
  if [[ "${HTTP_STATUS}" != 200 ]]; then
    echo "ERROR: user initialization failed (HTTP ${HTTP_STATUS}):" >&2
    jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
    echo "       The endpoint only works while the registry has no users.  If the" >&2
    echo "       registry was initialized outside this script, there is no stored" >&2
    echo "       credential to recover — reset the registry state and the quay-*" >&2
    echo "       bootstrap Secrets, then re-run (see docs/local-cluster.md)." >&2
    exit 1
  fi
  TOKEN="$(jq -r '.access_token' < "${tmpdir}/response")"
  if [[ -z "${TOKEN}" || "${TOKEN}" == "null" ]]; then
    echo "ERROR: initialize succeeded but returned no access_token." >&2
    exit 1
  fi
  printf 'header = "Authorization: Bearer %s"\n' "${TOKEN}" > "${tmpdir}/auth.curlrc"
  apply_secret "${ADMIN_SECRET}" Opaque \
    "username=${ADMIN_USER}" "password=${ADMIN_PASS}" "token=${TOKEN}"
  echo "Created admin user '${ADMIN_USER}' and stored credentials in Secret ${ADMIN_SECRET}."
fi

# --- step 2: the holos organization -------------------------------------------

http GET "/api/v1/organization/${ORG}"
if [[ "${HTTP_STATUS}" == 200 ]]; then
  echo "Organization '${ORG}' exists; skipping."
elif [[ "${HTTP_STATUS}" != 404 ]]; then
  # 404 is the live-verified "no such organization" status; anything else
  # (401/403/5xx) is API trouble, not absence — fail rather than create.
  echo "ERROR: checking organization '${ORG}' failed (HTTP ${HTTP_STATUS}):" >&2
  jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
  exit 1
else
  jq -n --arg n "${ORG}" --arg e "${ORG_EMAIL}" '{name: $n, email: $e}' \
    > "${tmpdir}/request.json"
  http POST /api/v1/organization/ "${tmpdir}/request.json"
  if [[ "${HTTP_STATUS}" != 201 ]]; then
    echo "ERROR: creating organization '${ORG}' failed (HTTP ${HTTP_STATUS}):" >&2
    jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
    exit 1
  fi
  echo "Created organization '${ORG}'."
fi

# --- step 3: the organization robot account -----------------------------------

# Both the GET (exists) and PUT (created) responses carry the robot token;
# capture it inside each branch so the data flow stays explicit.
ROBOT_TOKEN=""
http GET "/api/v1/organization/${ORG}/robots/${ROBOT_SHORTNAME}"
if [[ "${HTTP_STATUS}" == 200 ]]; then
  echo "Robot account '${ROBOT}' exists; skipping."
  ROBOT_TOKEN="$(jq -r '.token' < "${tmpdir}/response")"
elif [[ "${HTTP_STATUS}" != 400 ]]; then
  # 400 ("Could not find robot with specified username") is the
  # live-verified "no such robot" status; anything else is API trouble.
  echo "ERROR: checking robot '${ROBOT}' failed (HTTP ${HTTP_STATUS}):" >&2
  jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
  exit 1
else
  jq -n '{description: "Bootstrap robot: pushes auto-create repositories under the holos org."}' \
    > "${tmpdir}/request.json"
  http PUT "/api/v1/organization/${ORG}/robots/${ROBOT_SHORTNAME}" "${tmpdir}/request.json"
  if [[ "${HTTP_STATUS}" != 201 ]]; then
    echo "ERROR: creating robot '${ROBOT}' failed (HTTP ${HTTP_STATUS}):" >&2
    jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
    exit 1
  fi
  echo "Created robot account '${ROBOT}'."
  ROBOT_TOKEN="$(jq -r '.token' < "${tmpdir}/response")"
fi
if [[ -z "${ROBOT_TOKEN}" || "${ROBOT_TOKEN}" == "null" ]]; then
  echo "ERROR: robot response carried no token." >&2
  exit 1
fi

# --- step 4: creator team membership ------------------------------------------

# A team with the creator role lets its members create repositories under
# the org, so a `docker push` to a not-yet-existing holos/<repo> succeeds
# by auto-creating the repository (verified live — see docs/local-cluster.md
# "Verify Quay").  The team PUT is an upsert, so it also repairs a drifted
# role on re-run; membership is checked first to keep the second run a
# strict no-op.
http GET "/api/v1/organization/${ORG}"
if [[ "${HTTP_STATUS}" != 200 ]]; then
  # Step 2 just ensured the org exists, so any non-200 here is API trouble
  # — fail rather than misread an error body as "team missing".
  echo "ERROR: reading organization '${ORG}' teams failed (HTTP ${HTTP_STATUS}):" >&2
  jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
  exit 1
fi
TEAM_ROLE="$(jq -r --arg t "${TEAM}" '.teams[$t].role // empty' < "${tmpdir}/response")"
if [[ "${TEAM_ROLE}" == "creator" ]]; then
  echo "Team '${TEAM}' exists with the creator role; skipping."
else
  jq -n '{role: "creator"}' > "${tmpdir}/request.json"
  http PUT "/api/v1/organization/${ORG}/team/${TEAM}" "${tmpdir}/request.json"
  if [[ "${HTTP_STATUS}" != 200 ]]; then
    echo "ERROR: creating team '${TEAM}' failed (HTTP ${HTTP_STATUS}):" >&2
    jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
    exit 1
  fi
  echo "Created team '${TEAM}' with the creator role."
fi

http GET "/api/v1/organization/${ORG}/team/${TEAM}/members"
if [[ "${HTTP_STATUS}" != 200 ]]; then
  echo "ERROR: listing team '${TEAM}' members failed (HTTP ${HTTP_STATUS}):" >&2
  jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
  exit 1
fi
if jq -e --arg r "${ROBOT}" '.members[] | select(.name == $r)' \
  < "${tmpdir}/response" >/dev/null; then
  echo "Robot '${ROBOT}' is a member of team '${TEAM}'; skipping."
else
  http PUT "/api/v1/organization/${ORG}/team/${TEAM}/members/${ROBOT}"
  if [[ "${HTTP_STATUS}" != 200 ]]; then
    echo "ERROR: adding robot '${ROBOT}' to team '${TEAM}' failed (HTTP ${HTTP_STATUS}):" >&2
    jq -r '.message? // .error_message? // .' < "${tmpdir}/response" >&2 || true
    exit 1
  fi
  echo "Added robot '${ROBOT}' to team '${TEAM}'."
fi

# --- step 5: in-cluster pull Secret -------------------------------------------

# kubernetes.io/dockerconfigjson built from the robot token, for later pull
# consumers (e.g. a future imagePullSecrets reference).  Note the scope
# boundary from HOL-1177: node-level containerd pulls of
# quay.holos.localhost images (DNS + CA trust on the k3d nodes) are a
# separate concern — this only provisions the credential.
DOCKERCONFIGJSON="$(jq -n --arg host "${QUAY_URL#https://}" \
  --arg auth "$(b64 "${ROBOT}:${ROBOT_TOKEN}")" \
  '{auths: {($host): {auth: $auth}}}')"
apply_secret "${PULL_SECRET}" kubernetes.io/dockerconfigjson \
  ".dockerconfigjson=${DOCKERCONFIGJSON}"

# --- done ---------------------------------------------------------------------

cat <<EOF

Quay bootstrap complete.

Admin credentials (UI login at ${QUAY_URL}):
  kubectl -n ${NAMESPACE} get secret ${ADMIN_SECRET} -o json \\
    | jq '.data | map_values(@base64d)'

Robot credentials (docker push/pull as ${ROBOT}):
  kubectl -n ${NAMESPACE} get secret ${PULL_SECRET} -o jsonpath='{.data.\\.dockerconfigjson}' \\
    | base64 -d | jq -r '.auths["${QUAY_URL#https://}"].auth' | base64 -d | cut -d: -f2- \\
    | docker login ${QUAY_URL#https://} -u '${ROBOT}' --password-stdin

Verify with a push (auto-creates the repository under ${ORG}/):
  docker pull busybox
  docker tag busybox ${QUAY_URL#https://}/${ORG}/sample:test
  docker push ${QUAY_URL#https://}/${ORG}/sample:test
EOF
