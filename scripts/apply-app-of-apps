#!/usr/bin/env bash
# App-of-Apps bootstrap handoff (HOL-1373/HOL-1378, separated out in HOL-1379).
#
# Hand ongoing platform reconciliation off to Argo CD, AFTER:
#
#   1. scripts/apply has brought up the imperative bootstrap FLOOR — the Layer 0
#      foundation, Quay, Keycloak, Argo CD, and Kargo — with `kubectl apply
#      --server-side`, in dependency order, with no dependency on Argo CD
#      reconciling anything; AND
#   2. the holos Quay ORGANIZATION has been provisioned by
#      scripts/apply-holos-quay-organization (HOL-1380) — the holos org and the
#      holos-controller repository in the in-cluster Quay — and the operator has
#      obtained the two credentials this script needs (both backed by a Quay
#      robot, per the guidance that script prints):
#        * HOST-SIDE PUSH auth for the `oras push` below — supplied via
#          ORAS_USERNAME / ORAS_PASSWORD or a prior `oras login` (a push-capable
#          robot credential; scripts/publish-config reads these, NOT any
#          in-cluster Secret); and
#        * the holos-paas-config-robot SOURCE Secret (the holos+robot PULL
#          credential, keys username/password) in the argocd namespace, which the
#          argocd-projects bootstrap Job turns into the holos-paas-config repo
#          Secret Argo CD pulls the bundle with.
#      The holos-paas-config repository itself is managed (pre-created) by
#      scripts/apply-holos-quay-organization, so the push robot needs only write
#      (push) access to it — no repo-create rights.
#
# That holos Quay setup is this script's EXPLICIT dependency, and the reason the
# handoff is a separate step from scripts/apply (HOL-1379).  On a freshly rebuilt
# cluster the Quay registries are not configured yet when scripts/apply finishes,
# so attempting the publish there would race the Quay setup and fail — the
# rebuild-time race this split breaks.  scripts/apply therefore STOPS at the
# floor (Quay and Keycloak up) and points through the HOL-1380 bootstrap steps;
# run this script LAST, once scripts/apply-holos-quay-organization has run and you
# have the robot push credential it describes.
#
# The handoff resolves the chicken-and-egg — Argo CD cannot reconcile the
# platform from the OCI config bundle until Argo CD itself is running — by
# running AFTER the floor:
#
#   1. Publish the holos-paas-config:dev bundle — a straight tar of the committed
#      holos/deploy/ tree (scripts/publish-config), pushed under the mutable :dev
#      tag the App-of-Apps Applications track.
#   2. Apply the two ROOT App-of-Apps Applications (the app-of-apps and projects
#      component dirs, DELIBERATELY excluded from scripts/apply's COMPONENTS so
#      they are applied here, once, as the handoff — not as part of the
#      imperative floor).  The platform root (Application platform-bootstrap,
#      spec.project: platform) fans out one child Application per system
#      component under the platform AppProject; the projects root (Application
#      projects-bootstrap, spec.project: projects) fans out the
#      project/application collection resources under the projects AppProject.
#      Argo CD then tracks :dev and reconciles the platform on every re-push (the
#      "Always" repo-cache TTL, see holos/docs/oci-publish-workflow.md).
#
# Idempotent by construction: re-running publishes the current committed render
# and re-applies the two roots (server-side apply converges).
#
# Unlike scripts/apply (the bootstrap floor, which must succeed on its own), a
# missing handoff prerequisite here is a HARD ERROR with guidance — this script's
# whole purpose IS the handoff, so it must not silently no-op.  The one exception
# is BOOTSTRAP_APP_OF_APPS_FORCE_ROOTS=1, which forces applying the roots even
# when the publish was skipped/failed or holos/deploy/ is dirty (e.g. a
# known-current :dev already in the registry).
#
# Environment overrides:
#   KUBE_CONTEXT                       — kubectl context to apply to (default: the
#                                        current context, which must be k3d-holos;
#                                        setting this explicitly is informed
#                                        consent to target another context)
#   CONFIG_REPO / CONFIG_TAG          — override the bundle target (defaults
#                                        mirror scripts/publish-config: the
#                                        in-cluster Quay config repo at :dev)
#   BOOTSTRAP_APP_OF_APPS_FORCE_ROOTS — set to 1 to apply the root Applications
#                                        even if the publish was skipped/failed or
#                                        holos/deploy/ is dirty relative to HEAD.
#                                        Does NOT skip the holos-paas-config repo
#                                        credential check — Argo CD still needs it
#                                        to pull the bundle.
#   REPO_BOOTSTRAP_TIMEOUT_SECONDS    — seconds to wait for the holos-paas-config
#                                        repo credential Secret to appear (default
#                                        300)
#
# Prerequisites (the manual holos Quay organization setup above):
#   - kubectl, with a context pointing at the target cluster
#   - oras (https://oras.land/docs/installation) and a reachable Quay
#   - host-side push auth for the oras push (ORAS_USERNAME / ORAS_PASSWORD or a
#     prior `oras login`)
#   - the holos-paas-config-robot SOURCE Secret in the argocd namespace (the
#     Argo CD pull credential)

set -euo pipefail

# Resolve the repo root so this script works from any working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
COMPONENTS_DIR="${REPO_ROOT}/holos/deploy/clusters/k3d-holos/components"

if ! command -v kubectl >/dev/null 2>&1; then
  echo "ERROR: 'kubectl' not found on PATH." >&2
  exit 1
fi
if [[ ! -d "${COMPONENTS_DIR}" ]]; then
  echo "ERROR: rendered manifests not found: ${COMPONENTS_DIR}" >&2
  echo "       The deploy tree is committed; is this a complete checkout?" >&2
  exit 1
fi

# Resolve and pin the target context before mutating anything: the manifests are
# rendered for the k3d-holos cluster, and a server-side apply with
# --force-conflicts seizes field ownership — refuse to do that to whatever
# context happens to be current unless it is k3d-holos or the operator explicitly
# opted in via KUBE_CONTEXT.  Mirrors scripts/apply's context gate.
if [[ -z "${KUBE_CONTEXT:-}" ]]; then
  KUBE_CONTEXT="$(kubectl config current-context)"
  if [[ "${KUBE_CONTEXT}" != "k3d-holos" ]]; then
    echo "ERROR: current kubectl context is '${KUBE_CONTEXT}', expected 'k3d-holos'." >&2
    echo "       The rendered manifests target the k3d-holos cluster.  Set" >&2
    echo "       KUBE_CONTEXT explicitly to apply to a different context." >&2
    exit 1
  fi
fi
echo "Will apply the App-of-Apps roots to kubectl context: ${KUBE_CONTEXT}"

if ! kubectl --context "${KUBE_CONTEXT}" version --request-timeout=10s >/dev/null 2>&1; then
  echo "ERROR: cannot reach the cluster for kubectl context '${KUBE_CONTEXT}'." >&2
  echo "       Bring up the platform floor with scripts/apply first (see docs/local-cluster.md)." >&2
  exit 1
fi

FORCE_ROOTS="${BOOTSTRAP_APP_OF_APPS_FORCE_ROOTS:-0}"

echo "==> App-of-Apps handoff: publish holos-paas-config bundle + apply the root Applications"

# 0. Source-consistency gate.  scripts/apply applied the WORKING-TREE manifests
#    under ${COMPONENTS_DIR}, but scripts/publish-config --build bundles the
#    COMMITTED tree (git archive HEAD:holos/deploy) — by design, so the bootstrap
#    :dev tag is always a reviewed, committed render.  If holos/deploy/ is dirty
#    relative to HEAD, the two sources diverge: the cluster has the working-tree
#    render while the published :dev (and thus the App-of-Apps roots) carries the
#    HEAD render, so Argo CD's selfHeal/prune would drag the cluster onto HEAD —
#    silently undoing the uncommitted local manifests.  Refuse the handoff when
#    holos/deploy/ is not clean at HEAD; commit the render (the scripts/render
#    diff-clean gate) and re-run, or override with
#    BOOTSTRAP_APP_OF_APPS_FORCE_ROOTS=1 if the divergence is intentional.
#
#    "Clean" must cover BOTH tracked modifications AND untracked files: a
#    brand-new, un-`git add`ed render file would be applied from the working tree
#    but omitted by `git archive HEAD:holos/deploy`, so the published bundle and
#    the roots would prune that just-applied file.  `git diff --quiet HEAD`
#    ignores untracked files, so check them separately with
#    `git ls-files --others --exclude-standard`.
deploy_dirty=0
if ! git -C "${REPO_ROOT}" diff --quiet HEAD -- holos/deploy 2>/dev/null; then
  deploy_dirty=1
elif [[ -n "$(git -C "${REPO_ROOT}" ls-files --others --exclude-standard -- holos/deploy 2>/dev/null)" ]]; then
  deploy_dirty=1
fi
if [[ "${FORCE_ROOTS}" != "1" && "${deploy_dirty}" -eq 1 ]]; then
  echo "ERROR: holos/deploy/ has uncommitted changes relative to HEAD (tracked edits or" >&2
  echo "       untracked files).  scripts/publish-config bundles the COMMITTED tree (HEAD)," >&2
  echo "       so publishing now would point the App-of-Apps roots at a render that differs" >&2
  echo "       from the working-tree manifests scripts/apply applied — Argo CD's selfHeal" >&2
  echo "       would undo them.  Commit the render (scripts/render is the diff-clean gate)" >&2
  echo "       and re-run, or set BOOTSTRAP_APP_OF_APPS_FORCE_ROOTS=1 if the divergence is" >&2
  echo "       intentional." >&2
  exit 1
fi

# 1. Publish the holos-paas-config:dev bundle.  This step requires oras, a
#    reachable Quay, and the holos-paas-config-robot push credential — i.e. the
#    manual holos Quay organization setup this script depends on.  Applying the
#    root Applications is GATED on a successful publish: the roots reconcile with
#    prune+selfHeal from holos-paas-config:dev, so applying them against a STALE
#    (or absent) :dev would drag the cluster back off the manifests scripts/apply
#    just applied.  A failed/skipped publish is therefore a HARD ERROR (unless
#    BOOTSTRAP_APP_OF_APPS_FORCE_ROOTS=1 forces the roots against a known-current
#    :dev).  scripts/publish-config --build is network-free; --push is the
#    credentialed network step.
published=0
if ! command -v oras >/dev/null 2>&1; then
  echo "    SKIP publish: 'oras' not found on PATH (https://oras.land/docs/installation)." >&2
elif "${REPO_ROOT}/scripts/publish-config" --build >&2 \
  && "${REPO_ROOT}/scripts/publish-config" --push >/dev/null; then
  echo "    Published holos-paas-config:${CONFIG_TAG:-dev} (the App-of-Apps :dev tag)."
  published=1
else
  echo "    WARNING: publishing holos-paas-config failed." >&2
fi

if [[ "${published}" -ne 1 && "${FORCE_ROOTS}" != "1" ]]; then
  echo "ERROR: holos-paas-config:${CONFIG_TAG:-dev} was not published this run, so the" >&2
  echo "       App-of-Apps handoff cannot proceed: applying the prune+selfHeal roots could" >&2
  echo "       drag the cluster back to a stale or absent :dev bundle." >&2
  echo "" >&2
  echo "       This step depends on the holos Quay ORGANIZATION being configured first:" >&2
  echo "         - the holos org in the in-cluster Quay (https://quay.holos.internal)," >&2
  echo "           provisioned by scripts/apply-holos-quay-organization (HOL-1380); and" >&2
  echo "         - HOST-SIDE PUSH auth for this oras push: a push-capable Quay robot" >&2
  echo "           credential, supplied via ORAS_USERNAME / ORAS_PASSWORD or a prior" >&2
  echo "           'oras login quay.holos.internal' (this script's oras push reads those," >&2
  echo "           NOT the in-cluster holos-paas-config-robot Secret, which is the Argo CD" >&2
  echo "           PULL credential handled below)." >&2
  echo "       See holos/docs/oci-publish-workflow.md (Registry transport and credentials)" >&2
  echo "       and docs/runbooks/quay-resource-controller-credentials.md." >&2
  echo "" >&2
  echo "       Install oras (https://oras.land/docs/installation) if missing, configure the" >&2
  echo "       holos Quay organization and host-side push auth, then re-run this script.  Set" >&2
  echo "       BOOTSTRAP_APP_OF_APPS_FORCE_ROOTS=1 to apply the roots against a :dev already" >&2
  echo "       current in the registry." >&2
  exit 1
fi

# 2. Ensure the Argo CD repository-credential Secret exists BEFORE applying the
#    roots.  Argo CD needs the holos-paas-config repository Secret (argocd-format,
#    in the argocd namespace) to PULL the OCI bundle the roots track; without it
#    the roots reconcile but cannot pull holos-paas-config:dev and stay Unknown.
#    That Secret is assembled create-if-absent by the argocd-projects component's
#    bootstrap Job from the manually-provisioned holos-paas-config-robot SOURCE
#    Secret.  scripts/apply ran that Job during the floor — BEFORE the operator
#    provisioned the source Secret — so it exited 0 WITHOUT creating the repo
#    Secret, and a Complete Job is never re-run by a plain apply.  So re-run the
#    bootstrap here, now that the source Secret should exist (mirroring
#    scripts/apply's pre_argocd_projects): pre-apply its ServiceAccount + RBAC,
#    delete the prior Job (foreground, so its pod is gone), and re-apply the Job.
#    Then poll until the repo Secret appears (the Job exits 0 even when it creates
#    nothing, so Complete does NOT imply the Secret exists — poll the Secret, the
#    real contract), failing fast on a Failed Job and erroring with guidance if
#    the source Secret is still missing at the deadline.
REPO_BOOTSTRAP_TIMEOUT_SECONDS="${REPO_BOOTSTRAP_TIMEOUT_SECONDS:-300}"
ensure_repo_credential() {
  local dir="${COMPONENTS_DIR}/argocd-projects"
  kubectl --context "${KUBE_CONTEXT}" apply --server-side --force-conflicts \
    -f "${dir}/serviceaccount-holos-paas-config-repo-bootstrap.yaml" \
    -f "${dir}/role-holos-paas-config-repo-bootstrap.yaml" \
    -f "${dir}/rolebinding-holos-paas-config-repo-bootstrap.yaml"
  kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
    delete job -l app.kubernetes.io/name=holos-paas-config-repo-bootstrap \
    --ignore-not-found --cascade=foreground --wait --request-timeout=60s
  kubectl --context "${KUBE_CONTEXT}" apply --server-side --force-conflicts \
    -f "${dir}/job-holos-paas-config-repo-bootstrap.yaml"

  local job=job/holos-paas-config-repo-bootstrap job_state
  local deadline=$((SECONDS + REPO_BOOTSTRAP_TIMEOUT_SECONDS))
  while true; do
    if kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
      get secret holos-paas-config --request-timeout=10s >/dev/null 2>&1; then
      echo "    Argo CD repository credential holos-paas-config is present."
      return 0
    fi
    if job_state=$(kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
      get "${job}" --ignore-not-found --request-timeout=10s \
      -o jsonpath='{range .status.conditions[*]}{.type}={.status}{"\n"}{end}' 2>/dev/null); then
      if grep -q '^Failed=True$' <<<"${job_state}"; then
        echo "ERROR: ${job} failed (e.g. the holos-paas-config-robot source Secret is malformed);" >&2
        echo "       inspect it with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace argocd describe ${job}" >&2
        return 1
      fi
    fi
    if ((SECONDS >= deadline)); then
      echo "ERROR: the Argo CD repository credential Secret holos-paas-config was not created" >&2
      echo "       within ${REPO_BOOTSTRAP_TIMEOUT_SECONDS}s.  The argocd-projects bootstrap Job creates it from the" >&2
      echo "       holos-paas-config-robot SOURCE Secret (keys username/password, the holos+robot" >&2
      echo "       PULL credential) in the argocd namespace — provision that Secret, then re-run:" >&2
      echo "         kubectl -n argocd create secret generic holos-paas-config-robot \\" >&2
      echo "           --from-literal=username=holos+robot --from-literal=password=<token>" >&2
      echo "       See docs/runbooks/quay-resource-controller-credentials.md and" >&2
      echo "       holos/docs/oci-publish-workflow.md." >&2
      return 1
    fi
    sleep 5
  done
}
# Always ensure the repo credential — even on the forced path.  FORCE_ROOTS
# bypasses the PUBLISH and source-consistency gates (a known-current :dev, an
# intentionally-dirty tree), but Argo CD still cannot pull the bundle without the
# holos-paas-config repo Secret, so skipping this here would reintroduce the
# round-1 failure mode (roots applied, bundle unpullable) under a documented flag.
# It is idempotent on the happy path (re-applying RBAC + re-running the bootstrap
# Job leaves an existing Secret untouched), and its poll checks the Secret before
# the deadline, so an already-present credential returns without any extra wait.
ensure_repo_credential || exit 1

# 3. Apply the two root App-of-Apps Applications.  These component dirs are NOT in
#    scripts/apply's COMPONENTS (the imperative floor) precisely so they are
#    applied here, once, as the Argo CD handoff.  The repository-credential Secret
#    (ensured above) and the platform/projects AppProjects already exist (applied
#    by the argocd-projects component in scripts/apply).  server-side apply
#    converges, so re-running is safe.
for root in app-of-apps projects; do
  echo "    apply root: ${root}"
  kubectl --context "${KUBE_CONTEXT}" apply --server-side --force-conflicts \
    -f "${COMPONENTS_DIR}/${root}/"
done

echo "    Argo CD now reconciles the platform (platform-bootstrap) and the"
echo "    project/application resources (projects-bootstrap) from"
echo "    holos-paas-config:${CONFIG_TAG:-dev}."
