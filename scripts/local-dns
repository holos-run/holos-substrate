#!/usr/bin/env bash
# Originally vendored from https://github.com/holos-run/holos/blob/main/doc/website/static/scripts/local-dns
# and modified locally since; this copy has diverged from upstream (see git log).
# Documentation: https://github.com/holos-run/holos/blob/main/doc/md/topics/local-cluster.mdx
#
# Configure macOS DNS to resolve *.holos.internal to 127.0.0.1 via dnsmasq.
# This is necessary for requests to reach the local k3d cluster.
#
# NOTE: This script is macOS-only. It uses Homebrew, launchctl, /etc/resolver,
# and mDNSResponder — all macOS-specific. Linux users should configure dnsmasq
# (or systemd-resolved) themselves to point *.holos.internal at 127.0.0.1.
# The MVP demo target is an Apple Silicon Mac (ADR-7).
#
# Prerequisites:
#   - macOS (Apple Silicon or Intel)
#   - Homebrew  (https://brew.sh/)
#   - sudo access (required to write /etc/resolver and manage LaunchDaemon)
#
# Run this script once before creating the cluster with scripts/local-k3d.

set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "ERROR: this script is macOS-only. See the header comment for Linux instructions." >&2
  exit 1
fi

# --- Prerequisite checks ---------------------------------------------------
# NOTE: check_prereq is duplicated verbatim in scripts/local-k3d and
# scripts/local-ca so each vendored script stays standalone.  Keep the three
# copies character-identical — CI (.github/workflows/ci.yaml) enforces this —
# and consolidate into a shared helper if a fourth copy appears.
check_prereq() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "ERROR: '$1' not found on PATH." >&2
    echo "       $2" >&2
    exit 1
  fi
}
check_prereq brew "Install from https://brew.sh/"
# ---------------------------------------------------------------------------

# Install dnsmasq if not already present (no-op and silent if already installed).
brew list dnsmasq >/dev/null 2>&1 || brew install dnsmasq

BREW_PREFIX="$(brew --prefix)"

# Ensure the dnsmasq.d directory exists (brew install creates it, but be safe).
mkdir -p "${BREW_PREFIX}/etc/dnsmasq.d"

# Best-effort cleanup of the retired loopback-TLD config left behind on
# machines that ran an earlier revision of this script (HOL-1364 moved the
# platform off the RFC 6761 loopback TLD onto holos.internal). Without this,
# the old wildcard keeps resolving locally and muddies migration
# troubleshooting. The old TLD is composed from a variable so the retired
# hostname never appears as a literal in this repo (keeps the repo-wide audit
# clean). Removal is best-effort: missing files are not an error.
OLD_TLD="holos.${LOCALHOST_TLD:-localhost}"
rm -f "${BREW_PREFIX}/etc/dnsmasq.d/${OLD_TLD}.conf"
sudo rm -f "/etc/resolver/${OLD_TLD}"

# Idempotent — overwriting an existing config with the same content is safe;
# the daemon reload below picks up any changes on re-runs.
cat <<EOF >"${BREW_PREFIX}/etc/dnsmasq.d/holos.internal.conf"
# Refer to https://holos.run/docs/tutorial/local/k3d/
address=/holos.internal/127.0.0.1
EOF

# -e tests existence regardless of permissions (correct intent for LaunchDaemon).
if [[ -e /Library/LaunchDaemons/homebrew.mxcl.dnsmasq.plist ]]; then
  echo "dnsmasq already installed; reloading to pick up any config changes..."
else
  # || true prevents set -e from exiting before the emptiness check below.
  plist="$(brew list dnsmasq | grep 'dnsmasq.plist$' | head -1 || true)"
  if [[ -z "$plist" ]]; then
    echo "ERROR: could not locate dnsmasq.plist in brew list output" >&2
    exit 1
  fi
  sudo cp "$plist" /Library/LaunchDaemons/homebrew.mxcl.dnsmasq.plist
  # No cache flush here: at this point the daemon is not yet loaded and
  # /etc/resolver/holos.internal is not yet written, so there is nothing to
  # flush. The `killall -HUP mDNSResponder` at the end of every run is what
  # reloads resolver state once the daemon and resolver entry are in place.
  echo "dnsmasq installed"
fi

# Reload the daemon in both branches so config changes always take effect.
# || true guards against launchctl unload returning nonzero when the service
# is not currently running (e.g. first install, crash, or manual stop).
sudo launchctl unload /Library/LaunchDaemons/homebrew.mxcl.dnsmasq.plist || true
sudo launchctl load /Library/LaunchDaemons/homebrew.mxcl.dnsmasq.plist

sudo mkdir -p /etc/resolver
# nameserver line is sufficient; macOS routes *.holos.internal to 127.0.0.1
# based on the resolver file name alone.
sudo tee /etc/resolver/holos.internal > /dev/null <<EOF
nameserver 127.0.0.1
EOF
# Flush the directory-services cache now that the resolver entry is in place,
# then HUP mDNSResponder to reload resolver state. The flush runs here — after
# the daemon is loaded and /etc/resolver/holos.internal is written — where it
# can actually drop stale entries.
sudo dscacheutil -flushcache
sudo killall -HUP mDNSResponder

echo "all done."
