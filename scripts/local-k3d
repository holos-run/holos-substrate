#!/bin/bash
# Vendored from https://github.com/holos-run/holos/blob/main/doc/md/topics/local-cluster.mdx
# Documentation: https://github.com/holos-run/holos/blob/main/doc/md/topics/local-cluster.mdx
#
# Create a local k3d cluster named "workload" with a local registry.
# If the cluster already exists, it is deleted and recreated (reset semantics).
#
# Prerequisites:
#   - k3d   (https://k3d.io/#installation)
#   - jq    (https://jqlang.org/) — used for cluster/registry existence checks
#   - Docker or OrbStack
#   - DNS configured via scripts/local-dns
#
# After creating the cluster, run scripts/local-ca to set up trusted TLS.
#
# Environment variable overrides (must match k3d/config.yaml when set):
#   CLUSTER_NAME   — cluster name for delete/exist checks  (default: workload)
#   REGISTRY_NAME  — registry hostname                     (default: registry.holos.localhost)
#   REGISTRY_PORT  — registry host port                    (default: 5100)
#
# Note: CLUSTER_NAME, REGISTRY_NAME, and REGISTRY_PORT control the delete/exist
# checks and the registry creation step only.  The cluster shape (port mappings,
# k3s args, registry use) is defined in k3d/config.yaml and must be edited
# separately if you want to override those values.

set -euo pipefail

CLUSTER_NAME="${CLUSTER_NAME:-workload}"
REGISTRY_NAME="${REGISTRY_NAME:-registry.holos.localhost}"
REGISTRY_PORT="${REGISTRY_PORT:-5100}"

# Resolve the repo root so this script works from any working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Delete existing cluster if present (reset semantics)
if k3d cluster list -o json | jq -e ".[] | select(.name == \"${CLUSTER_NAME}\")" > /dev/null 2>&1; then
  echo "Deleting existing cluster '${CLUSTER_NAME}'..."
  k3d cluster delete "${CLUSTER_NAME}"
fi

# Create local registry if it doesn't exist
if ! k3d registry list -o json | jq -e ".[] | select(.name == \"k3d-${REGISTRY_NAME}\")" > /dev/null 2>&1; then
  echo "Creating registry '${REGISTRY_NAME}' on port ${REGISTRY_PORT}..."
  k3d registry create "${REGISTRY_NAME}" --port "${REGISTRY_PORT}"
fi

# Create the workload cluster using the declarative config
echo "Creating cluster '${CLUSTER_NAME}' from ${REPO_ROOT}/k3d/config.yaml..."
k3d cluster create --config "${REPO_ROOT}/k3d/config.yaml"

echo "Cluster '${CLUSTER_NAME}' created successfully."
echo "Run scripts/local-ca to set up trusted TLS certificates."
