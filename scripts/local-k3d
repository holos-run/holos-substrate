#!/usr/bin/env bash
# Originally vendored from https://github.com/holos-run/holos/blob/main/doc/md/topics/local-cluster.mdx
# and modified locally since; this copy has diverged from upstream (see git log).
# Documentation: https://github.com/holos-run/holos/blob/main/doc/md/topics/local-cluster.mdx
#
# WARNING: If the cluster already exists it is DELETED and recreated (reset
# semantics). Any workloads or ephemeral state in the existing cluster will be
# lost. Press Ctrl-C during the countdown to abort.
#
# Create a local k3d cluster named "holos"
#
# Prerequisites:
#   - k3d    (https://k3d.io/#installation)
#   - jq     (https://jqlang.org/) — used for cluster/registry existence checks
#   - Docker or OrbStack (daemon must be running)
#   - DNS configured via scripts/local-dns
#
# After creating the cluster, run scripts/local-ca to set up trusted TLS.
#
# The static cluster shape (port mappings, k3s args) lives in k3d/config.yaml.
# Cluster name is passed at runtime.

set -euo pipefail

CLUSTER_NAME="holos"

# Resolve the repo root so this script works from any working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Prerequisite checks ---------------------------------------------------
# NOTE: check_prereq is duplicated verbatim in scripts/local-dns and
# scripts/local-ca so each vendored script stays standalone.  Keep the three
# copies character-identical — CI (.github/workflows/ci.yaml) enforces this —
# and consolidate into a shared helper if a fourth copy appears.
check_prereq() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "ERROR: '$1' not found on PATH." >&2
    echo "       $2" >&2
    exit 1
  fi
}
check_prereq k3d  "Install from https://k3d.io/#installation"
check_prereq jq   "Install from https://jqlang.org/"
check_prereq docker "Install Docker Desktop or OrbStack"

if ! docker info >/dev/null 2>&1; then
  echo "ERROR: Docker daemon is not running. Start Docker or OrbStack first." >&2
  exit 1
fi
# ---------------------------------------------------------------------------

# Delete existing cluster if present (reset semantics).
# Use jq --arg to avoid injection when the cluster name contains special chars.
if k3d cluster list -o json | jq -e --arg name "${CLUSTER_NAME}" '.[] | select(.name == $name)' >/dev/null; then
  echo "WARNING: Cluster '${CLUSTER_NAME}' already exists and will be DELETED."
  echo "Press Ctrl-C within 5 seconds to abort..."
  sleep 5
  echo "Deleting existing cluster '${CLUSTER_NAME}'..."
  k3d cluster delete "${CLUSTER_NAME}"
fi

# Create the cluster: static shape from config, name and registry passed at
# runtime so all three env vars are fully honored. The positional NAME argument
# overrides metadata.name in k3d/config.yaml.
echo "Creating cluster '${CLUSTER_NAME}' from ${REPO_ROOT}/k3d/config.yaml..."
k3d cluster create "${CLUSTER_NAME}" \
  --config "${REPO_ROOT}/k3d/config.yaml"

echo "Cluster '${CLUSTER_NAME}' created successfully."
echo "Run scripts/local-ca to set up trusted TLS certificates."
