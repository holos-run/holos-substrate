#!/usr/bin/env bash
# Originally vendored from https://github.com/holos-run/holos/blob/main/doc/website/static/scripts/local-ca
# and modified locally since; this copy has diverged from upstream (see git log).
# Documentation: https://github.com/holos-run/holos/blob/main/doc/md/topics/local-cluster.mdx
#
# Install a local mkcert root CA into the k3d cluster so cert-manager can
# issue trusted TLS certificates for *.holos.localhost.
#
# The local-ca Secret (cert-manager namespace) is the integration point for
# the local-ca ClusterIssuer (holos/components/local-ca).  This script creates
# the cert-manager namespace before cert-manager itself is installed — that is
# intentional: cert-manager's ClusterIssuer references the Secret, so the
# Secret must exist first.  Do not rename the namespace or the Secret.
#
# Prerequisites:
#   - mkcert   (https://github.com/FiloSottile/mkcert#installation)
#   - kubectl  (cluster must be reachable via current kubeconfig)
#   - sudo access (mkcert --install writes to the system trust store)
#     Run `sudo -v` before this script if your sudo timestamp has expired.
#
# Run this script after creating the cluster with scripts/local-k3d.
# The generated namespace.yaml and local-ca.yaml are saved to $(mkcert -CAROOT)
# (mode 0600 for local-ca.yaml) so you can reapply them after a cluster reset
# without re-running mkcert --install.

set -euo pipefail

# --- Prerequisite checks ---------------------------------------------------
# NOTE: check_prereq is duplicated verbatim in scripts/local-k3d and
# scripts/local-dns so each vendored script stays standalone.  Keep the three
# copies character-identical — CI (.github/workflows/ci.yaml) enforces this —
# and consolidate into a shared helper if a fourth copy appears.
check_prereq() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "ERROR: '$1' not found on PATH." >&2
    echo "       $2" >&2
    exit 1
  fi
}
check_prereq mkcert  "Install from https://github.com/FiloSottile/mkcert#installation"
check_prereq kubectl "Install from https://kubernetes.io/docs/tasks/tools/"
# ---------------------------------------------------------------------------

# Preflight: resolve the ambient kubeconfig context as a standalone statement
# so set -e aborts cleanly when no context is set, and report which cluster is
# targeted.  This runs before mkcert --install so a missing kubeconfig context
# fails fast, before anything mutates the system trust store or stages CA
# private key material.
KUBE_CONTEXT="$(kubectl config current-context)"
echo "Will apply manifests to kubectl context: ${KUBE_CONTEXT}"

mkcert --install

tmpdir="$(mktemp -d)"
finish() {
  [[ -d "$tmpdir" ]] && rm -rf "$tmpdir"
}
# A single EXIT trap is preferred over trapping ERR+INT+TERM: bash runs the
# EXIT trap exactly once on every termination path (normal exit, set -e
# failure, or a fatal SIGINT/SIGTERM), whereas combining EXIT with
# ERR/INT/TERM traps would run finish twice on error or interrupt.
trap finish EXIT

CAROOT="$(mkcert -CAROOT)"

# Copy CA files into the staging directory with tight permissions on the key.
# tls.crt and ca.crt are intentionally both set to rootCA.pem: cert-manager's
# CA Issuer requires tls.crt (the CA cert) and ca.crt (the trust anchor) and
# for a self-signed root both fields are the same certificate.
install -m 0644 "${CAROOT}/rootCA.pem" "${tmpdir}/ca.crt"
install -m 0644 "${CAROOT}/rootCA.pem" "${tmpdir}/tls.crt"
install -m 0600 "${CAROOT}/rootCA-key.pem" "${tmpdir}/tls.key"

# Build the local-ca Secret manifest directly with correct type: kubernetes.io/tls.
# Using a heredoc with explicit base64 fields avoids the 'kubectl create secret generic'
# pitfall where type: Opaque is emitted and cannot be overridden by appending a second
# 'type:' key.
#
# base64 | tr -d '\n' is the portable approach: BSD base64 (macOS) wraps at 60 chars
# and GNU base64 (Linux) wraps at 76 chars — neither supports the other's no-wrap flag
# (-b 0 vs -w 0), so stripping newlines with tr is required for cross-platform use.
CA_CRT_B64="$(base64 < "${tmpdir}/ca.crt" | tr -d '\n')"
TLS_CRT_B64="$(base64 < "${tmpdir}/tls.crt" | tr -d '\n')"
TLS_KEY_B64="$(base64 < "${tmpdir}/tls.key" | tr -d '\n')"

# Pre-create local-ca.yaml at mode 0600 before populating it with CA private key
# material.  The `install` sets the inode permissions; the subsequent `cat >` writes
# to the existing inode and inherits its permissions rather than creating a new file
# under the current umask.  Do not remove the `install` line — without it, `cat >`
# would create the file at umask-governed mode (typically 0644) before writing
# the private key, creating a brief window where the key is world-readable.
install -m 0600 /dev/null "${tmpdir}/local-ca.yaml"
cat > "${tmpdir}/local-ca.yaml" <<EOF
apiVersion: v1
kind: Secret
metadata:
  name: local-ca
  namespace: cert-manager
type: kubernetes.io/tls
data:
  ca.crt: ${CA_CRT_B64}
  tls.crt: ${TLS_CRT_B64}
  tls.key: ${TLS_KEY_B64}
EOF

# spec.finalizers is intentionally omitted: the kubernetes finalizer is injected
# by the API server automatically.  Declaring it in the manifest causes SSA
# field-ownership conflicts on some cluster versions.
#
# The istio.io/dataplane-mode label must stay in sync with the cert-manager
# entry in holos/namespaces.cue: this script and the namespaces component both
# server-side-apply this Namespace with kubectl's default field manager, so a
# re-run of this script with a manifest that omitted the label would silently
# strip it and de-enroll cert-manager from the ambient mesh.
cat > "${tmpdir}/namespace.yaml" <<EOF
apiVersion: v1
kind: Namespace
metadata:
  labels:
    istio.io/dataplane-mode: ambient
    kubernetes.io/metadata.name: cert-manager
  name: cert-manager
EOF

# Pin --context to the preflight-resolved value so the apply targets the same
# context that was reported, even if the ambient context changes while
# mkcert --install blocks on a sudo prompt.
kubectl apply --context "${KUBE_CONTEXT}" --server-side=true -f "${tmpdir}/namespace.yaml"
# namespace is declared in the manifest; -n flag omitted to avoid redundancy.
kubectl apply --context "${KUBE_CONTEXT}" --server-side=true -f "${tmpdir}/local-ca.yaml"

# Save the manifests to CAROOT for cluster resets.
# local-ca.yaml contains the CA private key — install it with mode 0600.
install -m 0644 "${tmpdir}/namespace.yaml" "${CAROOT}/namespace.yaml"
install -m 0600 "${tmpdir}/local-ca.yaml" "${CAROOT}/local-ca.yaml"

echo "local-ca Secret applied to cert-manager namespace."
echo "Saved namespace.yaml and local-ca.yaml to ${CAROOT} for cluster resets."
