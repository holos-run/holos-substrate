#!/usr/bin/env bash
# One-time Quay reset for the local k3d cluster: wipe Quay's Postgres database
# (and registry blob storage) so /api/v1/user/initialize re-opens and the
# quay-admin-bootstrap Job can mint the superuser OAuth token (HOL-1283).
#
# WHY THIS EXISTS
#   Quay's /api/v1/user/initialize endpoint only answers against a *virgin*
#   registry — the moment any user exists in Quay's database it closes
#   permanently.  A cluster that ran under the earlier OIDC-only config may
#   already hold SSO-provisioned users, which keeps initialize closed and
#   prevents quay-admin-bootstrap from ever writing the quay-initial-admin
#   Secret (key `token`) — even after the backend is switched to Database
#   (HOL-1282).  This helper destroys the Quay database so initialize re-opens,
#   then a normal `scripts/apply` re-runs the bootstrap against the now-virgin
#   DB.
#
#   This is a DELIBERATE, SEPARATE, DESTRUCTIVE operation.  scripts/apply is
#   NOT modified to wipe the DB on every run — the declarative apply stays
#   idempotent.  Run this only when you intend to discard all Quay registry
#   data (organizations, repositories, robots, images, users).
#
# WHAT IT DOES (every step is idempotent / safe to re-run)
#   1. Scales the Quay Deployment to zero so nothing holds the database open or
#      serves the stale admin user during the wipe.
#   2. Deletes the quay-initial-admin Secret so the one-shot initialize token
#      is re-minted (a stale Secret pointing at a wiped DB would otherwise make
#      every bootstrap path skip itself — see scripts/quay-init's guard).
#   3. Deletes the CNPG `quay-db` Cluster.  CNPG removes its managed PVCs with
#      it, so the next `scripts/apply` re-creates the Cluster and re-runs its
#      initdb against empty storage — a virgin `quay` database.
#   4. Deletes the registry blob-storage PVC (quay-datastorage) so no orphaned
#      blobs survive into the empty database.  scripts/apply re-creates it.
#
#   It deliberately leaves the quay-secret-keys Secret (DATABASE_SECRET_KEY /
#   SECRET_KEY) in place: those are registry crypto keys, independent of the
#   user database, and the secret-keys bootstrap Job is generate-once.
#
# AFTER RUNNING THIS, BRING QUAY BACK UP:
#
#   scripts/apply
#
#   wait_quay (in scripts/apply) gates on the quay-admin-bootstrap Job and the
#   quay-initial-admin Secret, so a successful apply proves the token was
#   minted against the virgin DB.
#
# VERIFY (requires the live local cluster; run after scripts/apply):
#
#   # The minted superuser token reaches the superuser API (expect HTTP 200):
#   TOKEN="$(kubectl -n quay get secret quay-initial-admin \
#     -o jsonpath='{.data.token}' | base64 -d)"
#   curl -sS -o /dev/null -w '%{http_code}\\n' \
#     -H "Authorization: Bearer ${TOKEN}" \
#     https://quay.holos.localhost/api/v1/superuser/users/
#   # => 200
#
#   # Bootstrap idempotency: with quay-initial-admin already present, re-running
#   # the bootstrap no-ops without error (it logs "already exists; leaving it
#   # untouched").  scripts/apply re-runs it on every apply via pre_quay:
#   scripts/apply
#   # => wait_quay passes; the Secret is unchanged.
#
# Environment overrides:
#   KUBE_CONTEXT — kubectl context to reset (default: the current context,
#                  which must be k3d-holos — the cluster these manifests are
#                  rendered for; setting it explicitly is informed consent to
#                  target another context, mirroring scripts/apply).
#
# Prerequisites:
#   - kubectl, with a context pointing at the cluster running Quay
#     (scripts/local-k3d creates the local cluster; see docs/local-cluster.md)
#
# NOTE: prerequisite checks are inline rather than a copy of the check_prereq
# helper shared verbatim by scripts/local-{ca,dns,k3d} — their NOTE blocks call
# for consolidating into a shared helper if a fourth copy appears, so this
# script (like scripts/apply and scripts/quay-init) deliberately avoids
# creating one.

set -euo pipefail

NAMESPACE="quay"
DB_CLUSTER="quay-db"
ADMIN_SECRET="quay-initial-admin"
DATASTORAGE_PVC="quay-datastorage"
QUAY_DEPLOYMENT="quay"

# A short request timeout keeps a hung apiserver connection from stalling the
# reset indefinitely; the deletes themselves use --wait so the script does not
# return while the database is still terminating.
REQUEST_TIMEOUT="30s"
# CNPG Cluster deletion cascades to the instance pods and PVCs, which drain in
# the background; give the foreground wait a generous budget.
DELETE_TIMEOUT="${DELETE_TIMEOUT:-300s}"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  # Print the leading comment block (the usage documentation) and exit.
  sed -n '2,/^set -euo pipefail$/{/^set -euo pipefail$/d;s/^# \{0,1\}//;p}' "$0"
  exit 0
fi

if ! command -v kubectl >/dev/null 2>&1; then
  echo "ERROR: 'kubectl' not found on PATH." >&2
  exit 1
fi

# Resolve and pin the target context before destroying anything: these
# manifests are rendered for the k3d-holos cluster, so refuse to wipe whatever
# context happens to be current unless it is k3d-holos or the operator
# explicitly opted in via KUBE_CONTEXT (the scripts/apply precedent).
if [[ -z "${KUBE_CONTEXT:-}" ]]; then
  KUBE_CONTEXT="$(kubectl config current-context)"
  if [[ "${KUBE_CONTEXT}" != "k3d-holos" ]]; then
    echo "ERROR: current kubectl context is '${KUBE_CONTEXT}', expected 'k3d-holos'." >&2
    echo "       This reset is destructive and targets the local k3d-holos cluster." >&2
    echo "       Set KUBE_CONTEXT explicitly to reset a different context." >&2
    exit 1
  fi
fi

if ! kubectl --context "${KUBE_CONTEXT}" version --request-timeout=10s >/dev/null 2>&1; then
  echo "ERROR: cannot reach the cluster for kubectl context '${KUBE_CONTEXT}'." >&2
  echo "       Create the local cluster with scripts/local-k3d (see docs/local-cluster.md)." >&2
  exit 1
fi
if ! kubectl --context "${KUBE_CONTEXT}" get namespace "${NAMESPACE}" \
  -o name --request-timeout="${REQUEST_TIMEOUT}" >/dev/null 2>&1; then
  echo "ERROR: namespace '${NAMESPACE}' does not exist in context '${KUBE_CONTEXT}'." >&2
  echo "       Nothing to reset; run scripts/apply first (see docs/local-cluster.md)." >&2
  exit 1
fi

cat >&2 <<WARNING
============================================================================
  WARNING: this DESTROYS all Quay registry data on context '${KUBE_CONTEXT}'.
============================================================================
  It deletes the Quay Postgres database (CNPG Cluster ${DB_CLUSTER} and its
  PVCs) and the registry blob storage (PVC ${DATASTORAGE_PVC}) in namespace
  '${NAMESPACE}'.  Every organization, repository, robot, image, and user is
  lost.  This re-opens /api/v1/user/initialize so the superuser token can be
  re-minted on the next scripts/apply.

  Proceeding in 5 seconds — press Ctrl-C to abort.
============================================================================
WARNING
sleep 5

echo "==> scaling Quay Deployment to zero (releasing DB connections)"
# --ignore-not-found keeps the reset idempotent: a partially-applied or
# already-reset cluster may not have the Deployment yet.  The scale is best
# effort — deleting the CNPG Cluster below severs the DB regardless — so a
# missing Deployment is not fatal.
kubectl --context "${KUBE_CONTEXT}" --namespace "${NAMESPACE}" \
  scale deployment "${QUAY_DEPLOYMENT}" --replicas=0 \
  --request-timeout="${REQUEST_TIMEOUT}" 2>/dev/null || true

echo "==> deleting the ${ADMIN_SECRET} Secret (forces a fresh initialize token)"
# Must precede the DB wipe conceptually but is order-independent in practice:
# leaving it would make quay-admin-bootstrap and scripts/quay-init both take
# their reuse path and skip re-initializing against the virgin DB, and the
# stale token would be rejected by the empty registry.
kubectl --context "${KUBE_CONTEXT}" --namespace "${NAMESPACE}" \
  delete secret "${ADMIN_SECRET}" \
  --ignore-not-found --request-timeout="${REQUEST_TIMEOUT}"

echo "==> deleting the CNPG Cluster ${DB_CLUSTER} (and its managed PVCs)"
# Deleting the Cluster cascades to its instance pods and the PVCs CNPG manages
# for it, so the next scripts/apply re-creates the Cluster and re-runs initdb
# against empty storage — a virgin 'quay' database.  --wait blocks until the
# Cluster object is gone so the re-apply cannot race a still-terminating one.
kubectl --context "${KUBE_CONTEXT}" --namespace "${NAMESPACE}" \
  delete cluster.postgresql.cnpg.io "${DB_CLUSTER}" \
  --ignore-not-found --wait --timeout="${DELETE_TIMEOUT}" \
  --request-timeout="${REQUEST_TIMEOUT}"

# Defense in depth: depending on the CNPG reclaim policy a Cluster's PVCs can
# outlive the Cluster object, which would let a re-created Cluster re-attach the
# old, populated volume instead of running initdb fresh.  Delete any PVC CNPG
# labels for this Cluster so the wipe is unconditional.  --ignore-not-found and
# the label selector make this a no-op when none remain.
echo "==> deleting any residual ${DB_CLUSTER} PVCs"
kubectl --context "${KUBE_CONTEXT}" --namespace "${NAMESPACE}" \
  delete pvc -l "cnpg.io/cluster=${DB_CLUSTER}" \
  --ignore-not-found --wait --timeout="${DELETE_TIMEOUT}" \
  --request-timeout="${REQUEST_TIMEOUT}"

echo "==> deleting the registry blob storage PVC ${DATASTORAGE_PVC}"
# The blob storage backs the registry's image layers; wiping it alongside the
# database avoids orphaned blobs referencing rows that no longer exist.
# scripts/apply re-creates the PVC (it is a committed manifest).
kubectl --context "${KUBE_CONTEXT}" --namespace "${NAMESPACE}" \
  delete pvc "${DATASTORAGE_PVC}" \
  --ignore-not-found --wait --timeout="${DELETE_TIMEOUT}" \
  --request-timeout="${REQUEST_TIMEOUT}"

cat <<DONE

Quay reset complete on context '${KUBE_CONTEXT}'.

The Quay database and blob storage are gone, so /api/v1/user/initialize is
re-opened.  Bring Quay back up and re-mint the superuser token:

  scripts/apply

Then verify the minted token reaches the superuser API (expect 200):

  TOKEN="\$(kubectl -n ${NAMESPACE} get secret ${ADMIN_SECRET} \\
    -o jsonpath='{.data.token}' | base64 -d)"
  curl -sS -o /dev/null -w '%{http_code}\\n' \\
    -H "Authorization: Bearer \${TOKEN}" \\
    https://quay.holos.localhost/api/v1/superuser/users/
DONE
