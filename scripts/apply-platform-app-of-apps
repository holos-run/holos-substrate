#!/usr/bin/env bash
# Platform App-of-Apps bootstrap handoff (HOL-1382, split out of the former
# scripts/apply-app-of-apps).
#
# Hand ongoing PLATFORM (system) reconciliation off to Argo CD.  This is the
# "clean cut line" HOL-1382 asks for: this script fully bootstraps the platform
# with the PLATFORM-level App-of-Apps and STOPS — it does NOT touch tenant
# projects.  Projects are handled separately and independently by
# scripts/apply-projects-app-of-apps (which fans out to
# scripts/apply-project-app-of-apps per project).  The two are COMPLETELY
# INDEPENDENT and never call each other.
#
# Run AFTER:
#   1. scripts/apply has brought up the imperative bootstrap FLOOR — the Layer 0
#      foundation, Quay, Keycloak, Argo CD, and Kargo — with `kubectl apply
#      --server-side`, in dependency order, with no dependency on Argo CD
#      reconciling anything; AND
#   2. the holos Quay ORGANIZATION has been provisioned by
#      scripts/apply-holos-quay-organization (HOL-1380) — the holos org and the
#      holos-controller + holos-paas-config repositories in the in-cluster Quay —
#      and the operator has obtained the ONE credential this script needs:
#        * HOST-SIDE PUSH auth for the `oras push` below — supplied via
#          ORAS_USERNAME / ORAS_PASSWORD or a prior `oras login` (a push-capable
#          Quay robot credential; scripts/publish-config reads these, NOT any
#          in-cluster Secret).
#      No PULL credential is needed: the holos-paas-config repository is PUBLIC
#      (HOL-1381), so Argo CD pulls the bundle anonymously.  The repository itself
#      is managed (pre-created) by scripts/apply-holos-quay-organization, so the
#      push robot needs only write (push) access to it — no repo-create rights.
#
# That holos Quay setup is this script's EXPLICIT dependency, and the reason the
# handoff is a separate step from scripts/apply (HOL-1379).  On a freshly rebuilt
# cluster the Quay registries are not configured yet when scripts/apply finishes,
# so attempting the publish there would race the Quay setup and fail — the
# rebuild-time race this split breaks.  scripts/apply therefore STOPS at the
# floor (Quay and Keycloak up) and points through the HOL-1380 bootstrap steps;
# run this script once scripts/apply-holos-quay-organization has run and you have
# the robot push credential it describes.
#
# The handoff resolves the chicken-and-egg — Argo CD cannot reconcile the
# platform from the OCI config bundle until Argo CD itself is running — by
# running AFTER the floor:
#
#   1. Publish the holos-paas-config:dev bundle — a straight tar of the committed
#      holos/deploy/ tree (scripts/publish-config), pushed under the mutable :dev
#      tag the platform App-of-Apps Applications track.
#   2. Apply the PLATFORM ROOT App-of-Apps Application (the app-of-apps component
#      dir, DELIBERATELY excluded from scripts/apply's COMPONENTS so it is applied
#      here, once, as the handoff — not as part of the imperative floor).  The
#      platform root (Application platform-bootstrap, spec.project: platform) fans
#      out one child Application per SYSTEM component under the platform AppProject.
#      Argo CD then tracks :dev and reconciles the platform on every re-push (the
#      "Always" repo-cache TTL, see holos/docs/oci-publish-workflow.md).
#
# Idempotent by construction: re-running publishes the current committed render
# and re-applies the platform root (server-side apply converges).
#
# Unlike scripts/apply (the bootstrap floor, which must succeed on its own), a
# missing handoff prerequisite here is a HARD ERROR with guidance — this script's
# whole purpose IS the handoff, so it must not silently no-op.  The one exception
# is PLATFORM_APP_OF_APPS_FORCE_ROOT=1, which forces applying the root even when
# the publish was skipped/failed or holos/deploy/ is dirty (e.g. a known-current
# :dev already in the registry).
#
# Environment overrides:
#   KUBE_CONTEXT                  — kubectl context to apply to (default: the
#                                   current context, which must be k3d-holos;
#                                   setting this explicitly is informed consent to
#                                   target another context)
#   CONFIG_REPO / CONFIG_TAG      — override the bundle target (defaults mirror
#                                   scripts/publish-config: the in-cluster Quay
#                                   config repo at :dev)
#   PLATFORM_APP_OF_APPS_FORCE_ROOT — set to 1 to apply the platform root even if
#                                   the publish was skipped/failed or holos/deploy/
#                                   is dirty relative to HEAD.
#
# Prerequisites (the manual holos Quay organization setup above):
#   - kubectl, with a context pointing at the target cluster
#   - oras (https://oras.land/docs/installation) and a reachable Quay
#   - host-side push auth for the oras push (ORAS_USERNAME / ORAS_PASSWORD or a
#     prior `oras login`)
#   (No Argo CD pull credential: the holos-paas-config repository is public,
#    HOL-1381, so Argo CD pulls the bundle anonymously.)

set -euo pipefail

# Resolve the repo root so this script works from any working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
COMPONENTS_DIR="${REPO_ROOT}/holos/deploy/clusters/k3d-holos/components"

if ! command -v kubectl >/dev/null 2>&1; then
  echo "ERROR: 'kubectl' not found on PATH." >&2
  exit 1
fi
if [[ ! -d "${COMPONENTS_DIR}" ]]; then
  echo "ERROR: rendered manifests not found: ${COMPONENTS_DIR}" >&2
  echo "       The deploy tree is committed; is this a complete checkout?" >&2
  exit 1
fi

# Resolve and pin the target context before mutating anything: the manifests are
# rendered for the k3d-holos cluster, and a server-side apply with
# --force-conflicts seizes field ownership — refuse to do that to whatever
# context happens to be current unless it is k3d-holos or the operator explicitly
# opted in via KUBE_CONTEXT.  Mirrors scripts/apply's context gate.
if [[ -z "${KUBE_CONTEXT:-}" ]]; then
  KUBE_CONTEXT="$(kubectl config current-context)"
  if [[ "${KUBE_CONTEXT}" != "k3d-holos" ]]; then
    echo "ERROR: current kubectl context is '${KUBE_CONTEXT}', expected 'k3d-holos'." >&2
    echo "       The rendered manifests target the k3d-holos cluster.  Set" >&2
    echo "       KUBE_CONTEXT explicitly to apply to a different context." >&2
    exit 1
  fi
fi
echo "Will apply the platform App-of-Apps root to kubectl context: ${KUBE_CONTEXT}"

if ! kubectl --context "${KUBE_CONTEXT}" version --request-timeout=10s >/dev/null 2>&1; then
  echo "ERROR: cannot reach the cluster for kubectl context '${KUBE_CONTEXT}'." >&2
  echo "       Bring up the platform floor with scripts/apply first (see docs/local-cluster.md)." >&2
  exit 1
fi

FORCE_ROOT="${PLATFORM_APP_OF_APPS_FORCE_ROOT:-0}"

echo "==> Platform App-of-Apps handoff: publish holos-paas-config bundle + apply the platform root"

# 0. Source-consistency gate.  scripts/apply applied the WORKING-TREE manifests
#    under ${COMPONENTS_DIR}, but scripts/publish-config --build bundles the
#    COMMITTED tree (git archive HEAD:holos/deploy) — by design, so the bootstrap
#    :dev tag is always a reviewed, committed render.  If holos/deploy/ is dirty
#    relative to HEAD, the two sources diverge: the cluster has the working-tree
#    render while the published :dev (and thus the platform root) carries the HEAD
#    render, so Argo CD's selfHeal/prune would drag the cluster onto HEAD —
#    silently undoing the uncommitted local manifests.  Refuse the handoff when
#    holos/deploy/ is not clean at HEAD; commit the render (the scripts/render
#    diff-clean gate) and re-run, or override with PLATFORM_APP_OF_APPS_FORCE_ROOT=1
#    if the divergence is intentional.
#
#    "Clean" must cover BOTH tracked modifications AND untracked files: a
#    brand-new, un-`git add`ed render file would be applied from the working tree
#    but omitted by `git archive HEAD:holos/deploy`, so the published bundle and
#    the root would prune that just-applied file.  `git diff --quiet HEAD`
#    ignores untracked files, so check them separately with
#    `git ls-files --others --exclude-standard`.
deploy_dirty=0
if ! git -C "${REPO_ROOT}" diff --quiet HEAD -- holos/deploy 2>/dev/null; then
  deploy_dirty=1
elif [[ -n "$(git -C "${REPO_ROOT}" ls-files --others --exclude-standard -- holos/deploy 2>/dev/null)" ]]; then
  deploy_dirty=1
fi
if [[ "${FORCE_ROOT}" != "1" && "${deploy_dirty}" -eq 1 ]]; then
  echo "ERROR: holos/deploy/ has uncommitted changes relative to HEAD (tracked edits or" >&2
  echo "       untracked files).  scripts/publish-config bundles the COMMITTED tree (HEAD)," >&2
  echo "       so publishing now would point the platform root at a render that differs" >&2
  echo "       from the working-tree manifests scripts/apply applied — Argo CD's selfHeal" >&2
  echo "       would undo them.  Commit the render (scripts/render is the diff-clean gate)" >&2
  echo "       and re-run, or set PLATFORM_APP_OF_APPS_FORCE_ROOT=1 if the divergence is" >&2
  echo "       intentional." >&2
  exit 1
fi

# 1. Publish the holos-paas-config:dev bundle.  This step requires oras, a
#    reachable Quay, and a host-side push credential (ORAS_USERNAME/ORAS_PASSWORD
#    or a prior `oras login`) — i.e. the manual holos Quay organization setup this
#    script depends on.  Applying the platform root is GATED on a successful
#    publish: the root reconciles with prune+selfHeal from holos-paas-config:dev,
#    so applying it against a STALE (or absent) :dev would drag the cluster back
#    off the manifests scripts/apply just applied.  A failed/skipped publish is
#    therefore a HARD ERROR (unless PLATFORM_APP_OF_APPS_FORCE_ROOT=1 forces the
#    root against a known-current :dev).  scripts/publish-config --build is
#    network-free; --push is the credentialed network step.
published=0
if ! command -v oras >/dev/null 2>&1; then
  echo "    SKIP publish: 'oras' not found on PATH (https://oras.land/docs/installation)." >&2
elif "${REPO_ROOT}/scripts/publish-config" --build >&2 \
  && "${REPO_ROOT}/scripts/publish-config" --push >/dev/null; then
  echo "    Published holos-paas-config:${CONFIG_TAG:-dev} (the platform App-of-Apps :dev tag)."
  published=1
else
  echo "    WARNING: publishing holos-paas-config failed." >&2
fi

if [[ "${published}" -ne 1 && "${FORCE_ROOT}" != "1" ]]; then
  echo "ERROR: holos-paas-config:${CONFIG_TAG:-dev} was not published this run, so the" >&2
  echo "       platform App-of-Apps handoff cannot proceed: applying the prune+selfHeal root" >&2
  echo "       could drag the cluster back to a stale or absent :dev bundle." >&2
  echo "" >&2
  echo "       This step depends on the holos Quay ORGANIZATION being configured first:" >&2
  echo "         - the holos org in the in-cluster Quay (https://quay.holos.internal)," >&2
  echo "           provisioned by scripts/apply-holos-quay-organization (HOL-1380); and" >&2
  echo "         - HOST-SIDE PUSH auth for this oras push: a push-capable Quay robot" >&2
  echo "           credential, supplied via ORAS_USERNAME / ORAS_PASSWORD or a prior" >&2
  echo "           'oras login quay.holos.internal'.  No PULL credential is needed:" >&2
  echo "           the holos-paas-config repository is public, so Argo CD pulls the" >&2
  echo "           bundle anonymously (HOL-1381)." >&2
  echo "       See holos/docs/oci-publish-workflow.md (Registry transport and credentials)" >&2
  echo "       and docs/runbooks/quay-resource-controller-credentials.md." >&2
  echo "" >&2
  echo "       Install oras (https://oras.land/docs/installation) if missing, configure the" >&2
  echo "       holos Quay organization and host-side push auth, then re-run this script.  Set" >&2
  echo "       PLATFORM_APP_OF_APPS_FORCE_ROOT=1 to apply the root against a :dev already" >&2
  echo "       current in the registry." >&2
  exit 1
fi

# 2. Apply the PLATFORM root App-of-Apps Application.  This component dir is NOT in
#    scripts/apply's COMPONENTS (the imperative floor) precisely so it is applied
#    here, once, as the Argo CD handoff.  The platform AppProject and the
#    credential-less holos-paas-config repository registration Secret already exist
#    (applied by the argocd-projects component in scripts/apply).  Argo CD pulls the
#    bundle ANONYMOUSLY: the repository is PUBLIC (HOL-1381 — holos-quay-organization
#    sets its visibility to public), so no robot pull credential is needed; the
#    registration Secret carries only url/type/insecure (the insecure flag is still
#    required for the in-cluster Quay's mkcert serving cert).  server-side apply
#    converges, so re-running is safe.
echo "    apply platform root: app-of-apps"
kubectl --context "${KUBE_CONTEXT}" apply --server-side --force-conflicts \
  -f "${COMPONENTS_DIR}/app-of-apps/"

# 3. One-time migration cleanup (HOL-1382): prune the RETIRED global tenant
#    App-of-Apps.  Before HOL-1382 a single `projects` App-of-Apps reconciled ALL
#    projects from the SHARED holos-paas-config bundle: the root `projects-bootstrap`
#    and its two children `projects-project` / `projects-application`.  HOL-1382
#    removes the `projects` component (those paths are GONE from the republished
#    bundle) and replaces it with per-project `<project>-control-plane` /
#    `<project>-workload` roots over per-project bundles.  On a cluster that already
#    ran the old handoff, those three Applications LINGER: `projects-bootstrap`'s
#    source path vanished from the bundle (it errors, cannot self-prune its
#    children), and `projects-project`/`projects-application` either keep
#    reconciling the shared bundle's project/application paths IN PARALLEL with the
#    new per-project roots (a second manager) or go invalid once argocd-projects
#    narrows the `projects` AppProject sourceRepos to the per-project bundles.
#    Delete all three explicitly (idempotent --ignore-not-found; a no-op on a fresh
#    cluster) so the migration is clean.  This is platform-bootstrap's natural
#    finalization of the bundle migration it just republished.
echo "    prune retired global tenant App-of-Apps (one-time HOL-1382 migration)"
kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
  delete application.argoproj.io \
  projects-bootstrap projects-project projects-application \
  --ignore-not-found --request-timeout=60s

echo "    Argo CD now reconciles the platform (platform-bootstrap) from"
echo "    holos-paas-config:${CONFIG_TAG:-dev}."
echo "    Tenant projects are bootstrapped separately and independently:"
echo "      scripts/apply-projects-app-of-apps   # all projects' control planes"
