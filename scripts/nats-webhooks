#!/usr/bin/env bash
# Print the most recent retained/unacked messages from the NATS WEBHOOKS
# WorkQueue stream over the host-facing secure WebSocket endpoint
# (wss://nats.holos.localhost, HOL-1228/HOL-1230). The webhook-receiver
# publishes every inbound webhook body to this stream; this is the one-command
# debugging affordance to see the last N raw bodies still retained. A WorkQueue
# only retains a message until a consumer acks it, so once the webhook-subscriber
# has drained a message it is gone — this prints what is currently retained, not
# a historical event log.
#
# Read-only and consumer-free: it reads each message by sequence with
# `nats stream get`, which fetches directly from the stream without creating a
# consumer and without acking. This matters because WEBHOOKS is a file-backed
# WorkQueue stream drained by the webhook-subscriber's durable consumer — a
# WorkQueue deletes each message once it is acked, and rejects a second
# consumer whose subject filter overlaps an existing one. So we never run
# `nats sub`, `nats stream view`, or `nats consumer add` on `webhooks.>`; an
# ack or overlapping consumer would destroy real work.
#
# No NATS credentials are required: local development runs NATS unauthenticated
# (the MVP no-auth posture) and the shared Istio Gateway terminates TLS for
# *.holos.localhost, forwarding to the plain WebSocket port.
#
# Prerequisites:
#   - the `nats` CLI (https://github.com/nats-io/natscli)
#   - jq  (https://jqlang.github.io/jq/)
#   - a running local cluster (scripts/apply) reachable at nats.holos.localhost
#
# Usage:
#   scripts/nats-webhooks [count]   # count defaults to 10
#
# Environment:
#   NATS_URL       override the server URL (default wss://nats.holos.localhost)
#   NATS_MAX_SCAN  cap on sequences probed before giving up (default 10000;
#                  must be a positive integer)

set -euo pipefail

SERVER="${NATS_URL:-wss://nats.holos.localhost}"
STREAM="WEBHOOKS"
COUNT="${1:-10}"
# Cap on how many sequence numbers to probe before giving up. WEBHOOKS is a
# WorkQueue: acked messages are deleted, so the sequence window can stretch far
# ahead of the live messages (an old unacked message at first_seq with many
# newer drained sequences). Without a bound the scan below would run one
# `nats stream get` per deleted sequence — possibly thousands. Override with
# NATS_MAX_SCAN if you genuinely need to reach further back.
MAX_SCAN="${NATS_MAX_SCAN:-10000}"

case "$COUNT" in
  '' | *[!0-9]*)
    echo "ERROR: count must be a non-negative integer, got: $COUNT" >&2
    exit 1
    ;;
esac

# NATS_MAX_SCAN controls whether messages are inspected at all, so a bad value
# (empty, non-numeric, or zero) must fail loudly rather than silently scanning
# nothing and reporting "stopped after scanning 0 sequences".
case "$MAX_SCAN" in
  '' | *[!0-9]*)
    echo "ERROR: NATS_MAX_SCAN must be a positive integer, got: $MAX_SCAN" >&2
    exit 1
    ;;
esac
if [ "$MAX_SCAN" -eq 0 ]; then
  echo "ERROR: NATS_MAX_SCAN must be a positive integer, got: $MAX_SCAN" >&2
  exit 1
fi

# Read the stream's sequence window directly from JetStream metadata. This does
# not create a consumer; `nats stream info` only reports state.
info="$(nats --server "$SERVER" stream info "$STREAM" --json)"
messages="$(jq -r '.state.messages' <<<"$info")"
first_seq="$(jq -r '.state.first_seq' <<<"$info")"
last_seq="$(jq -r '.state.last_seq' <<<"$info")"

# A drained WorkQueue can report messages == 0 while first_seq/last_seq remain
# non-zero, so test the live count, not the sequence window.
if [ "$messages" -eq 0 ]; then
  echo "no messages on stream $STREAM"
  exit 0
fi

# Newest first: walk back from last_seq toward first_seq, printing at most COUNT
# messages. Each `nats stream get <seq>` is a non-destructive read by sequence.
# WEBHOOKS is a WorkQueue, so acked messages are deleted and their sequences
# leave gaps; `nats stream get` on a missing sequence exits non-zero. Treat only
# that specific "no message found" case as a skippable gap — only printed
# messages count toward COUNT, so a deleted newest sequence never hides the
# older ones still present. Any other read failure (timeout, auth/TLS, server
# error, CLI incompatibility) is fatal: silently skipping it would print
# nothing and exit 0, a false "nothing retained" result that hides a real
# problem from whoever is debugging. Bound the probe count with MAX_SCAN so a
# wide gap between live messages can never trigger an unbounded run of calls.
seq="$last_seq"
shown=0
probes=0
while [ "$seq" -ge "$first_seq" ] && [ "$shown" -lt "$COUNT" ] && [ "$probes" -lt "$MAX_SCAN" ]; do
  err="$(mktemp)"
  if msg="$(nats --server "$SERVER" stream get "$STREAM" "$seq" 2>"$err")"; then
    echo "===== ${STREAM} sequence ${seq} ====="
    printf '%s\n' "$msg"
    shown=$((shown + 1))
  elif grep -qiE 'no message found|message not found|not found' "$err"; then
    : # deleted/acked sequence — expected gap in a WorkQueue, skip it
  else
    echo "ERROR: reading $STREAM sequence $seq failed:" >&2
    cat "$err" >&2
    rm -f "$err"
    exit 1
  fi
  rm -f "$err"
  seq=$((seq - 1))
  probes=$((probes + 1))
done

if [ "$shown" -lt "$COUNT" ] && [ "$seq" -ge "$first_seq" ]; then
  echo "note: stopped after scanning $MAX_SCAN sequences (found $shown of $COUNT requested); raise NATS_MAX_SCAN to look further back" >&2
fi
