#!/usr/bin/env bash
# Apply the rendered platform manifests — the Layer 0 foundation and the
# Layer 1 services — to the cluster in dependency order.
#
# Applies each component under holos/deploy/clusters/k3d-holos/components/
# with server-side apply, in the order documented in holos/README.md ("How
# rendered manifests reach the cluster"), gating only on the critical
# dependencies between components: CRD establishment before the controllers
# that need the types, the istiod rollout before the Gateway is programmed,
# the ambient data-plane DaemonSets before enrolled workloads start, the
# cert-manager webhook before the components that create cert-manager.io
# resources, the CNPG operator rollout before the cnpg-clusters component's
# postgresql.cnpg.io Cluster resources (its admission webhooks fail
# closed), Cluster readiness before the Keycloak and Quay phases' database
# consumers, the Keycloak operator rollout before the keycloak component's
# k8s.keycloak.org custom resources, the Keycloak CR Ready and realm
# import Done conditions as the Layer 1 smoke check, the keycloak-config
# realm-reconciliation Job completion (the keycloak-config-cli run that
# converges the holos realm's roles, default group, and Argo CD client), the quay
# Deployment rollout as the Quay smoke check, and the Argo CD workload
# rollouts as the Argo CD smoke check.  The README is the canonical
# explanation of why the order is what it is; this script encodes exactly
# that order.
#
# The NATS event-driven deployment pipeline (the nats backbone plus the
# webhook-receiver and webhook-subscriber rollouts) was retired in HOL-1241:
# Kargo plus the client-side ORAS publish workflow (ADR-16) now own
# deployment, superseding the deprecated receiver/subscriber/deployer path
# (ADR-9/10/11/14).
#
# Idempotent by construction: server-side apply and kubectl wait both
# converge, so re-running against a fresh, partially applied, or fully
# applied cluster is safe.  Note the istiod webhook caveat in the README:
# every re-apply of istio-base or istiod transiently downgrades the
# validation webhook's failurePolicy until istiod re-patches it.
#
# To add a component: add its name to the COMPONENTS array below in
# dependency order, and define a wait_<name>() function (hyphens become
# underscores) only if a later component critically depends on it being
# ready.
#
# Environment overrides:
#   KUBE_CONTEXT     — kubectl context to apply to (default: the current
#                      context, which must be k3d-holos — the cluster these
#                      manifests are rendered for; setting this explicitly
#                      is informed consent to target another context)
#   CRD_TIMEOUT      — kubectl wait timeout for CRD establishment (default: 120s)
#   ROLLOUT_TIMEOUT  — rollout status timeout (default: 300s)
#   KEYCLOAK_TIMEOUT — timeout for each Keycloak gate: the Keycloak CR
#                      Ready condition and the realm import Done condition
#                      (default: 600s; the first start pulls the server
#                      image and runs DB migrations, so it gets a more
#                      generous budget than ROLLOUT_TIMEOUT)
#   QUAY_TIMEOUT     — timeout for the quay Deployment rollout gate
#                      (default: 900s; the gate must cover the first pull
#                      of the large Quay image plus the pod's own 600s
#                      startupProbe budget for DB schema migrations, so it
#                      gets a more generous budget than ROLLOUT_TIMEOUT)
#
# Prerequisites:
#   - kubectl, with a context pointing at the target cluster
#     (scripts/local-k3d creates the local cluster; see docs/local-cluster.md)
#
# NOTE: prerequisite checks are inline rather than a copy of the check_prereq
# helper shared verbatim by scripts/local-{ca,dns,k3d} — their NOTE blocks
# call for consolidating into a shared helper if a fourth copy appears, so
# this script deliberately avoids creating one.

set -euo pipefail

# Resolve the repo root so this script works from any working directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
COMPONENTS_DIR="${REPO_ROOT}/holos/deploy/clusters/k3d-holos/components"

# CRD establishment is fast; rollouts may pull images on first run.
CRD_TIMEOUT="${CRD_TIMEOUT:-120s}"
ROLLOUT_TIMEOUT="${ROLLOUT_TIMEOUT:-300s}"
KEYCLOAK_TIMEOUT="${KEYCLOAK_TIMEOUT:-600s}"
QUAY_TIMEOUT="${QUAY_TIMEOUT:-900s}"

# Convert a kubectl-style duration composed of h/m/s components (e.g.
# 300s, 5m, or 1h30m) to whole seconds for shell arithmetic.  Rejects
# anything else with a clear error: empty input and bare numbers without a
# unit (which kubectl also rejects), plus sub-second units — a stricter
# whole-second grammar than kubectl's, fitting a poll loop that ticks in
# seconds.  The 10# prefix forces base-10 arithmetic so leading zeros
# (e.g. 090s) are not misread as octal.
duration_seconds() {
  local duration="$1" rest="$1" total=0
  if [[ ! "${duration}" =~ ^([0-9]+[hms])+$ ]]; then
    echo "ERROR: cannot parse duration '${duration}' (expected e.g. 300s, 5m, 1h30m)." >&2
    return 1
  fi
  while [[ "${rest}" =~ ^([0-9]+)([hms]) ]]; do
    case "${BASH_REMATCH[2]}" in
      h) total=$((total + 10#${BASH_REMATCH[1]} * 3600)) ;;
      m) total=$((total + 10#${BASH_REMATCH[1]} * 60)) ;;
      s) total=$((total + 10#${BASH_REMATCH[1]})) ;;
    esac
    rest="${rest:${#BASH_REMATCH[0]}}"
  done
  echo "${total}"
}

# wait_quay's poll loop needs ROLLOUT_TIMEOUT as whole seconds for its
# deadline arithmetic (the other gates hand their timeouts verbatim to
# kubectl).  Parse it up front so a malformed override fails the run
# immediately rather than crashing the final gate after a long bootstrap.
ROLLOUT_TIMEOUT_SECONDS="$(duration_seconds "${ROLLOUT_TIMEOUT}")" || exit 1

# Platform components, in apply order.  The order encodes the six ordering
# rules documented in holos/README.md: namespaces first, CRDs before their
# controllers, istiod before the Gateway, the ambient data plane before
# enrolled workloads, fail-closed admission webhooks (cert-manager, the
# CNPG operator) before the components that create the resources they
# admit, and the Gateway before components that attach routes.  cnpg-crds
# and cnpg trail echo: CNPG depends only on its own CRDs (and, being
# ambient-enrolled, the data plane), so appending it keeps the existing
# order stable.  cnpg-clusters trails cnpg: its Cluster resources need the
# operator's fail-closed webhook serving before they can apply.
# keycloak-operator-crds and keycloak-operator trail cnpg-clusters: the
# Keycloak operator depends only on its own CRDs and the keycloak
# namespace, and the keycloak component's Keycloak CR needs both the
# operator reconciling and the keycloak-db Cluster reachable, so gating the
# operator rollout after the database keeps the dependency chain linear.
# keycloak trails the operator: its k8s.keycloak.org CRs need the operator
# reconciling and its cert-manager.io Certificate needs the cert-manager
# webhook admitting (hence the retried apply, like local-ca).  keycloak-config
# trails keycloak: its keycloak-config-cli Job reconciles the holos realm
# against the live admin API, so the Keycloak server must be Ready and the realm
# shell imported (both gated by wait_keycloak) before it runs; its own gate
# waits on the Job completing.  quay trails
# keycloak-config: it needs the quay-db Cluster reachable (gated Ready in the
# cnpg-clusters step) and attaches routes to the shared Gateway, so
# appending it keeps the established order stable.  argocd-crds and argocd
# close the sequence: CRDs before the controllers that need the types (the
# same guardrail as the other *-crds pairs), and Argo CD depends only on
# the Gateway its HTTPRoutes attach to — its OIDC backchannel reaches the
# Keycloak issuer through a ServiceEntry it ships itself (resolved by the
# mesh, applied with the component) — nothing downstream depends on it
# during bootstrap — so appending the pair keeps the established order
# stable.  kargo-crds and kargo close the sequence: CRDs before the controllers
# that need the kargo.akuity.io types (the same guardrail as the other *-crds
# pairs), and Kargo depends only on its own CRDs, the Gateway its HTTPRoutes
# attach to, and cert-manager (the chart's internal webhooks server uses
# cert-manager-issued self-signed certs) — all applied earlier — so appending
# the pair keeps the established order stable.  Nothing downstream depends on
# Kargo during bootstrap.  kargo-project-echo and kargo-echo wire the echo
# delivery pipeline (HOL-1240) and close the sequence: the Project is a
# kargo.akuity.io custom resource, so it trails kargo-crds (its type) and kargo
# (the controller that reconciles it into the kargo-echo namespace); kargo-echo's
# Warehouse and Stage are namespaced into that Project namespace, so they trail
# the Project, which scripts/apply gates on (wait_kargo_project_echo) so the
# namespace exists before they apply.  The argocd-update promotion step the Stage
# runs targets the echo Argo CD Application in the argocd namespace, applied here
# too; Argo CD itself was applied earlier (argocd).  Nothing during bootstrap
# depends on these.  my-project closes the sequence (HOL-1269/HOL-1270): it emits
# the Layer 3 sample app's Argo CD AppProject + Application AND its Kargo control
# plane (Project, ProjectConfig with a quay webhook receiver, Warehouse, the
# project-config promotion Stage, and the webhook-token bootstrap Job), so it
# trails argocd (its argoproj.io types and controller) and kargo (its
# kargo.akuity.io types and controller).  pre_my_project deletes the prior
# webhook-token bootstrap Job so each apply runs a fresh idempotent generate;
# wait_my_project gates the bootstrap Job's completion and the Kargo Project's
# adoption of the my-project namespace.  The Application stays Unknown until
# scripts/publish pushes the first my-project-config OCI artifact; nothing during
# bootstrap depends on it.
COMPONENTS=(
  namespaces
  gateway-api
  cert-manager-crds
  istio-base
  istiod
  istio-cni
  istio-ztunnel
  cert-manager
  local-ca
  istio-gateway
  echo
  cnpg-crds
  cnpg
  cnpg-clusters
  keycloak-operator-crds
  keycloak-operator
  keycloak
  keycloak-config
  quay
  argocd-crds
  argocd
  kargo-crds
  kargo
  kargo-project-echo
  kargo-echo
  my-project
)

# local-ca and istio-gateway create cert-manager.io resources (ClusterIssuer,
# Certificate) that cert-manager's fail-closed validating webhook must admit.
# Even after the webhook Deployment is Available there is a brief window,
# while cainjector injects the webhook's CA bundle, in which admission fails
# with a transient x509 error (see holos/README.md) — retry those applies
# instead of aborting the bootstrap.  cnpg-clusters has the same shape of
# window: the CNPG operator's fail-closed webhooks may briefly reject
# postgresql.cnpg.io resources after the controller-manager rollout is
# Available, so its apply retries too.  keycloak creates a cert-manager.io
# Certificate, so it shares the cert-manager webhook retry window.
apply_attempts() {
  case "$1" in
    local-ca | istio-gateway | cnpg-clusters | keycloak) echo 10 ;;
    *) echo 1 ;;
  esac
}

# Wait for every CRD a component ships to be Established, by waiting on the
# component's own customresourcedefinition-*.yaml files rather than
# `crd --all`, which would couple the gate to unrelated CRDs.
wait_crds_established() {
  local component="$1" crd_file args=()
  for crd_file in "${COMPONENTS_DIR}/${component}"/customresourcedefinition-*.yaml; do
    # Without nullglob an unmatched glob yields the literal pattern; fail
    # with a clear message instead of a confusing kubectl path error.
    if [[ ! -e "${crd_file}" ]]; then
      echo "ERROR: no customresourcedefinition-*.yaml files found for component '${component}'." >&2
      return 1
    fi
    args+=(-f "${crd_file}")
  done
  kubectl --context "${KUBE_CONTEXT}" wait --for=condition=Established \
    --timeout="${CRD_TIMEOUT}" "${args[@]}"
}

# Per-component wait gates, run after the component's apply.  Components
# without a gate (namespaces, istio-cni, local-ca, istio-gateway) simply
# define no function: namespace creation is synchronous, istio-cni is gated
# together with ztunnel below, and ClusterIssuer readiness, certificate
# issuance, and Gateway route attachment are all level-triggered.

# gateway-api: the Gateway/HTTPRoute types must exist before istio-gateway
# and echo apply.
wait_gateway_api() {
  wait_crds_established gateway-api
}

# cert-manager-crds: cert-manager requires its types at startup, and
# local-ca and istio-gateway create cert-manager.io resources.
wait_cert_manager_crds() {
  wait_crds_established cert-manager-crds
}

# istio-base: istiod requires the Istio types at startup.
wait_istio_base() {
  wait_crds_established istio-base
}

# istiod: must be running before the Gateway applies so the istio
# GatewayClass exists and istiod can program the Gateway.
wait_istiod() {
  kubectl --context "${KUBE_CONTEXT}" --namespace istio-system \
    rollout status deployment/istiod --timeout="${ROLLOUT_TIMEOUT}"
}

# istio-ztunnel: ambient capture (the istio-cni node agent applied just
# before, plus ztunnel) must be active before enrolled workloads start.
wait_istio_ztunnel() {
  kubectl --context "${KUBE_CONTEXT}" --namespace istio-system \
    rollout status daemonset/istio-cni-node --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace istio-system \
    rollout status daemonset/ztunnel --timeout="${ROLLOUT_TIMEOUT}"
}

# cert-manager: its validating webhook fails closed, so it must be serving
# before local-ca's ClusterIssuer and istio-gateway's Certificate apply.
wait_cert_manager() {
  kubectl --context "${KUBE_CONTEXT}" --namespace cert-manager \
    rollout status deployment/cert-manager-webhook --timeout="${ROLLOUT_TIMEOUT}"
}

# echo: waiting for its rollout is a smoke check that the enrolled workload
# starts under ambient capture.  It does not exercise the Gateway or
# HTTPRoute attachment — verify the traffic path separately.
wait_echo() {
  kubectl --context "${KUBE_CONTEXT}" --namespace echo \
    rollout status deployment/echo --timeout="${ROLLOUT_TIMEOUT}"
}

# cnpg-crds: the CNPG operator requires its types at startup, and the next
# phase applies postgresql.cnpg.io Cluster resources.
wait_cnpg_crds() {
  wait_crds_established cnpg-crds
}

# cnpg: the operator's admission webhooks for postgresql.cnpg.io resources
# fail closed, so the controller-manager must be serving before the
# cnpg-clusters component's Cluster resources can apply.
wait_cnpg() {
  kubectl --context "${KUBE_CONTEXT}" --namespace cnpg-system \
    rollout status deployment/cnpg-controller-manager --timeout="${ROLLOUT_TIMEOUT}"
}

# cnpg-clusters: the Keycloak phase applies a Keycloak CR that needs a
# reachable database, so gate on each Cluster's Ready condition (CNPG sets
# Ready when the Cluster reports "Cluster in healthy state").  The first
# reconcile pulls the multi-arch ghcr.io/cloudnative-pg/postgresql image,
# which may be slow — ROLLOUT_TIMEOUT covers it.
wait_cnpg_clusters() {
  kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
    wait cluster/keycloak-db --for=condition=Ready --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace quay \
    wait cluster/quay-db --for=condition=Ready --timeout="${ROLLOUT_TIMEOUT}"
}

# keycloak-operator-crds: the Keycloak operator requires its types at
# startup, and the next phase applies k8s.keycloak.org custom resources.
wait_keycloak_operator_crds() {
  wait_crds_established keycloak-operator-crds
}

# keycloak-operator: the keycloak component applies Keycloak and
# KeycloakRealmImport CRs that need the operator reconciling, so gate on its
# rollout.  The first pull of the multi-arch
# quay.io/keycloak/keycloak-operator image may be slow — ROLLOUT_TIMEOUT
# covers it.
wait_keycloak_operator() {
  kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
    rollout status deployment/keycloak-operator --timeout="${ROLLOUT_TIMEOUT}"
}

# keycloak: the Layer 1 smoke check.  First the Keycloak CR Ready condition
# — the server started against the CNPG database with its TLS certificate —
# then the KeycloakRealmImport Done condition, so the script cannot exit
# successfully while the holos realm import Job is still running or has
# failed (a failed import never reaches Done and times out here; the
# operator's import Job only starts once the server is Ready, hence the
# wait order).  The first reconcile pulls the multi-arch
# quay.io/keycloak/keycloak image and runs the database schema migrations,
# so both waits get the more generous KEYCLOAK_TIMEOUT.  Route attachment
# is level-triggered; verify the traffic path separately (see
# holos/README.md).
wait_keycloak() {
  kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
    wait keycloak/keycloak --for=condition=Ready --timeout="${KEYCLOAK_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
    wait keycloakrealmimport/holos --for=condition=Done --timeout="${KEYCLOAK_TIMEOUT}"
}

# keycloak-config: ensure every apply runs a fresh realm reconcile.  A completed
# Job's pod template is immutable and kubectl apply never re-runs an existing
# Complete Job, so without this pre-apply delete a reconcile would be skipped
# whenever the rendered Job already exists Complete on the cluster.  The Job's
# name carries a content hash of the realm import document and image (the
# realm-config component's CONFIG_HASH), which makes a forward config change
# render a new name — but that alone does not cover reverting to a
# previously-applied config within the Job's 24h TTL: the prior hash's Job would
# still be present and Complete, and the apply would not re-run it (the residual
# bug the round-2 review flagged).  Deleting every keycloak-config Job by label
# before the apply closes the whole class: the apply always creates a brand-new
# Job that runs the CLI, and because keycloak-config-cli converges idempotently,
# re-running on every apply is exactly the intended "reconcile on every apply"
# behavior.  --ignore-not-found tolerates the first apply (no Job yet) and the
# post-TTL-GC case.  --cascade=foreground with --wait blocks until the old Job
# AND its dependent CLI pod are fully gone before returning: the default
# background cascade only waits for the Job object to disappear, which would let a
# still-running CLI pod from an interrupted prior apply race the fresh reconcile
# and, if it finished last, leave the realm in a stale state (the round-3 review
# finding).  The longer request timeout covers foreground deletion blocking on
# the pod's own termination.
pre_keycloak_config() {
  kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
    delete job -l app.kubernetes.io/name=keycloak-config \
    --ignore-not-found --cascade=foreground --wait --request-timeout=60s
  # Also delete the quay-oidc secret bootstrap Job for the same reason: its name
  # is constant (no config hash), so a prior Complete OR Failed Job is never
  # re-run by apply.  A Failed bootstrap that never created the quay-oidc Secret
  # would otherwise wedge wait_keycloak_config forever.  The Job is idempotent
  # (it exits 0 leaving existing Secrets untouched), so recreating it on every
  # apply just re-verifies — and repairs a missing — copy in either namespace.
  # The Secrets it created survive the Job deletion (they are separate objects),
  # so the generate-once guarantee holds.
  kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
    delete job -l app.kubernetes.io/name=quay-oidc-bootstrap \
    --ignore-not-found --cascade=foreground --wait --request-timeout=60s
}

# keycloak-config: the realm-reconciliation smoke check.  The keycloak-config-cli
# Job converges the holos realm's three platform roles, the authenticated default
# group, and the Argo CD OIDC client against the live admin API — the point of
# this component — and the Job depends on the server serving, so gating here
# names the actual culprit in the error instead of a generic timeout.
#
# pre_keycloak_config above deletes any prior Job before the apply, so the apply
# always creates a fresh Job and this gate waits on a genuinely new run — never a
# stale Complete Job from an earlier apply (including a revert to a previously
# applied config within the TTL window).  The Job name is read from the rendered
# manifest the apply step just used — the single committed
# job-keycloak-config-*.yaml under the component's deploy directory — so the gate
# waits on exactly that Job (its name carries the config hash) rather than
# label-matching, which keeps the gate robust even if a delete ever leaves a
# terminating same-label Job mid-poll.  The glob is scoped to the reconcile Job's
# keycloak-config- prefix so the component's other Jobs (the quay-oidc secret
# bootstrap, rendered as job-quay-oidc-bootstrap.yaml) never match it.
#
# The Job is polled instead of handed to `kubectl wait --for=condition=Complete`
# so a Failed Job fails the gate on the next poll rather than blocking the full
# ROLLOUT_TIMEOUT before erroring.  The Job carries a ttlSecondsAfterFinished, so
# absence is tolerated — already garbage-collected on a long-bootstrapped cluster
# (or mid-poll), with the realm state it converged still in Keycloak's database —
# and --ignore-not-found makes that discrimination structural: absent yields
# empty output with exit 0, while a persistent lookup failure (RBAC, API error)
# fails the gate rather than silently skipping it (the wait_quay
# precedent).  The Job's own availability check retries until Keycloak answers, so
# polling it while the server is still settling after wait_keycloak is safe: it
# converges once the admin API responds.
wait_keycloak_config() {
  local job_state lookup_failures=0
  # Resolve the rendered Job's name from the committed manifest the apply just
  # used, so the gate waits on exactly that Job (its name carries the config
  # hash).  Exactly one job-keycloak-config-*.yaml renders per apply (the
  # reconcile Job); the prefix excludes the component's quay-oidc bootstrap Job.
  # Fail clearly if that assumption breaks rather than silently waiting on the
  # wrong object.
  local job_file job_files=("${COMPONENTS_DIR}/keycloak-config"/job-keycloak-config-*.yaml)
  if [[ ${#job_files[@]} -ne 1 || ! -e "${job_files[0]}" ]]; then
    echo "ERROR: expected exactly one keycloak-config reconcile job manifest, found ${#job_files[@]}." >&2
    return 1
  fi
  job_file="${job_files[0]}"
  local job_name
  job_name=$(kubectl --context "${KUBE_CONTEXT}" \
    get -f "${job_file}" -o jsonpath='{.metadata.name}' --request-timeout=10s 2>/dev/null) || true
  if [[ -z "${job_name}" ]]; then
    # The cluster read failed (e.g. the Job was already TTL-GC'd between apply
    # and gate); fall back to the name in the manifest itself.
    job_name=$(awk '/^metadata:/{m=1} m&&/^  name:/{print $2; exit}' "${job_file}")
  fi
  if [[ -z "${job_name}" ]]; then
    echo "ERROR: could not determine keycloak-config Job name from ${job_file}." >&2
    return 1
  fi
  local job="job/${job_name}"
  local deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
  while true; do
    # One read captures both existence and state: absent yields empty
    # output; present yields the Job name followed by one Type=Status line
    # per status condition.  --request-timeout bounds each poll so a hung
    # apiserver connection cannot stall past the script-owned deadline.
    if job_state=$(kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
      get "${job}" --ignore-not-found --request-timeout=10s \
      -o jsonpath='{.metadata.name}{"\n"}{range .status.conditions[*]}{.type}={.status}{"\n"}{end}'); then
      lookup_failures=0
      if [[ -z "${job_state}" ]] || grep -q '^Complete=True$' <<<"${job_state}"; then
        break
      fi
      if grep -q '^Failed=True$' <<<"${job_state}"; then
        echo "ERROR: ${job} failed; inspect it with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace keycloak describe ${job}" >&2
        return 1
      fi
    else
      # kubectl's own stderr has already flowed through above.  A single
      # failed read may be a transient apiserver or network blip — only a
      # persistent failure (e.g. RBAC) aborts the gate.
      lookup_failures=$((lookup_failures + 1))
      if ((lookup_failures >= 3)); then
        echo "ERROR: cannot query ${job}: ${lookup_failures} consecutive lookup failures." >&2
        return 1
      fi
    fi
    if ((SECONDS >= deadline)); then
      echo "ERROR: timed out after ${ROLLOUT_TIMEOUT} waiting for ${job} to complete." >&2
      return 1
    fi
    sleep 5
  done

  # The quay-oidc bootstrap Job (job-quay-oidc-bootstrap.yaml) generates the
  # shared OIDC client secret once and writes the quay-oidc Secret into BOTH the
  # keycloak namespace (consumed by the reconcile Job above) and the quay
  # namespace (consumed by the Quay Deployment in HOL-1219).  The reconcile Job
  # only reads the keycloak-side copy, so a bootstrap that does not fully succeed
  # — a partial write that left one namespace without the Secret, or a mismatch
  # between two pre-existing copies that the Job exits non-zero on — would
  # otherwise let the reconcile Job complete while leaving the quay side wrong.
  #
  # Gate the bootstrap Job's own outcome first: pre_keycloak_config recreates it
  # on every apply, so it is present here, and a Failed Job (including the
  # mismatch-detection exit) fails the gate by name instead of surfacing two
  # components later in quay.  The Job carries a ttlSecondsAfterFinished, so an
  # absent Job is tolerated (already GC'd on a long-lived session) and falls
  # through to the Secret check below.  Polled rather than `kubectl wait` so a
  # Failed Job fails on the next poll instead of blocking the full timeout.
  local boot_state boot_lookup_failures=0
  local boot_deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
  while true; do
    if boot_state=$(kubectl --context "${KUBE_CONTEXT}" --namespace keycloak \
      get job/quay-oidc-bootstrap --ignore-not-found --request-timeout=10s \
      -o jsonpath='{.metadata.name}{"\n"}{range .status.conditions[*]}{.type}={.status}{"\n"}{end}'); then
      boot_lookup_failures=0
      if [[ -z "${boot_state}" ]] || grep -q '^Complete=True$' <<<"${boot_state}"; then
        break
      fi
      if grep -q '^Failed=True$' <<<"${boot_state}"; then
        echo "ERROR: job/quay-oidc-bootstrap failed (e.g. the quay-oidc Secret differs between namespaces); inspect it with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace keycloak describe job/quay-oidc-bootstrap" >&2
        return 1
      fi
    else
      boot_lookup_failures=$((boot_lookup_failures + 1))
      if ((boot_lookup_failures >= 3)); then
        echo "ERROR: cannot query job/quay-oidc-bootstrap: ${boot_lookup_failures} consecutive lookup failures." >&2
        return 1
      fi
    fi
    if ((SECONDS >= boot_deadline)); then
      echo "ERROR: timed out after ${ROLLOUT_TIMEOUT} waiting for job/quay-oidc-bootstrap to complete." >&2
      return 1
    fi
    sleep 5
  done

  # Defense in depth for the GC'd-Job case above: the Secret's existence in both
  # namespaces is the actual contract Phase 2 (HOL-1219) depends on, so verify it
  # directly even when the bootstrap Job is gone.
  local ns
  for ns in keycloak quay; do
    local secret_deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
    while true; do
      if kubectl --context "${KUBE_CONTEXT}" --namespace "${ns}" \
        get secret quay-oidc --request-timeout=10s >/dev/null 2>&1; then
        break
      fi
      if ((SECONDS >= secret_deadline)); then
        echo "ERROR: timed out after ${ROLLOUT_TIMEOUT} waiting for the quay-oidc Secret in namespace ${ns}; inspect the bootstrap Job with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace keycloak describe job/quay-oidc-bootstrap" >&2
        return 1
      fi
      sleep 5
    done
  done
}

# quay: force a fresh admin-bootstrap Job on every apply.  Its name is
# constant (no config hash), so a prior Complete OR Failed Job is never re-run
# by `kubectl apply` (a completed Job's pod template is immutable).  A Failed
# admin-bootstrap that never created the quay-initial-admin Secret would
# otherwise wedge wait_quay's gate forever.  The Job is idempotent — it exits 0
# leaving an existing Secret untouched — so recreating it on every apply just
# re-verifies (and repairs) the credential.  The Secret it created survives the
# Job deletion (separate objects), so the generate-once guarantee holds.  This
# is the pre_keycloak_config precedent applied to quay (HOL-1276).
# --ignore-not-found tolerates the first apply (no Job yet) and the post-TTL-GC
# case; --cascade=foreground --wait blocks until the old Job and its pod are
# fully gone so a stale pod cannot race the fresh attempt.
#
# Pre-apply the admin-bootstrap ServiceAccount + RBAC before deleting the Job:
# `kubectl apply -f <dir>` applies a component's files in alphabetical order, so
# job-quay-admin-bootstrap.yaml is created before
# serviceaccount-quay-admin-bootstrap.yaml — on a fresh cluster the Job's pod
# would fail admission ("error looking up service account") until the SA lands.
# Pre-applying the identity here closes that race (the pre_my_project
# precedent), then the main apply re-applies it idempotently.
pre_quay() {
  local dir="${COMPONENTS_DIR}/quay"
  kubectl --context "${KUBE_CONTEXT}" apply --server-side --force-conflicts \
    -f "${dir}/serviceaccount-quay-admin-bootstrap.yaml" \
    -f "${dir}/role-quay-admin-bootstrap.yaml" \
    -f "${dir}/rolebinding-quay-admin-bootstrap.yaml"
  kubectl --context "${KUBE_CONTEXT}" --namespace quay \
    delete job -l app.kubernetes.io/name=quay-admin-bootstrap \
    --ignore-not-found --cascade=foreground --wait --request-timeout=60s
}

# quay: the Quay smoke check.  First the secret-keys bootstrap Job — the
# pod's initContainer cannot resolve its Secret env until it completes, so
# gating here names the actual culprit in the error instead of a generic
# rollout timeout.  The Job is polled instead of handed to `kubectl wait
# --for=condition=Complete` so a Failed Job fails the gate on the next poll
# rather than blocking the full ROLLOUT_TIMEOUT before erroring.  The Job
# carries a ttlSecondsAfterFinished, so absence is tolerated — already
# garbage-collected on a long-bootstrapped cluster (or mid-poll), with the
# Secret it created still in place (a Job that Failed and was then
# garbage-collected is indistinguishable; that failure surfaces as the
# rollout timeout below) — and --ignore-not-found makes that
# discrimination structural: absent yields empty output with exit 0, while
# a persistent lookup failure (RBAC, API error) fails the gate rather than
# silently skipping it.  Then the Deployment rollout:
# QUAY_TIMEOUT must cover the first pull of the large multi-arch
# quay.io/projectquay/quay image, the init container, and the database
# schema migrations inside the pod's own 600s startupProbe budget, hence
# its default exceeds that budget.  Route attachment is level-triggered;
# verify the traffic path separately (see holos/README.md).
wait_quay() {
  local job=job/quay-secret-keys-bootstrap job_state lookup_failures=0
  local deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
  while true; do
    # One read captures both existence and state: absent yields empty
    # output; present yields the Job name followed by one Type=Status line
    # per status condition.  --request-timeout bounds each poll so a hung
    # apiserver connection cannot stall past the script-owned deadline.
    if job_state=$(kubectl --context "${KUBE_CONTEXT}" --namespace quay \
      get "${job}" --ignore-not-found --request-timeout=10s \
      -o jsonpath='{.metadata.name}{"\n"}{range .status.conditions[*]}{.type}={.status}{"\n"}{end}'); then
      lookup_failures=0
      if [[ -z "${job_state}" ]] || grep -q '^Complete=True$' <<<"${job_state}"; then
        break
      fi
      if grep -q '^Failed=True$' <<<"${job_state}"; then
        echo "ERROR: ${job} failed; inspect it with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace quay describe ${job}" >&2
        return 1
      fi
    else
      # kubectl's own stderr has already flowed through above.  A single
      # failed read may be a transient apiserver or network blip — only a
      # persistent failure (e.g. RBAC) aborts the gate.
      lookup_failures=$((lookup_failures + 1))
      if ((lookup_failures >= 3)); then
        echo "ERROR: cannot query ${job}: ${lookup_failures} consecutive lookup failures." >&2
        return 1
      fi
    fi
    if ((SECONDS >= deadline)); then
      echo "ERROR: timed out after ${ROLLOUT_TIMEOUT} waiting for ${job} to complete." >&2
      return 1
    fi
    sleep 5
  done
  kubectl --context "${KUBE_CONTEXT}" --namespace quay \
    rollout status deployment/quay --timeout="${QUAY_TIMEOUT}"

  # Then the admin-bootstrap Job: it seeds the first superuser through Quay's
  # one-shot /api/v1/user/initialize endpoint and stores the returned OAuth
  # token in the quay-initial-admin Secret (HOL-1276) — the credential
  # downstream declarative bootstrap Jobs (e.g. my-project-quay-bootstrap)
  # authenticate to Quay's REST API with.  The Job self-waits on the rollout
  # the gate above just confirmed, then initializes; gating it here names the
  # actual culprit if the credential never materialises instead of surfacing it
  # as a "secrets quay-initial-admin not found" failure in a later component.
  # pre_quay recreates the Job on every apply, so it is present here; gate_job
  # tolerates a TTL-GC'd Job (the Secret check below is the real contract) — the
  # wait_keycloak_config quay-oidc precedent.
  gate_job quay quay-admin-bootstrap || return 1

  # Defense in depth for the GC'd-Job case: the quay-initial-admin Secret is
  # the actual contract downstream Jobs depend on, so verify it directly even
  # when the admin-bootstrap Job is already gone.
  local secret_deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
  while true; do
    if kubectl --context "${KUBE_CONTEXT}" --namespace quay \
      get secret quay-initial-admin --request-timeout=10s >/dev/null 2>&1; then
      break
    fi
    if ((SECONDS >= secret_deadline)); then
      echo "ERROR: timed out after ${ROLLOUT_TIMEOUT} waiting for the quay-initial-admin Secret; inspect the bootstrap Job with:" >&2
      echo "       kubectl --context ${KUBE_CONTEXT} --namespace quay describe job/quay-admin-bootstrap" >&2
      return 1
    fi
    sleep 5
  done
}

# argocd-crds: the Argo CD controllers require the argoproj.io types at
# startup.
wait_argocd_crds() {
  wait_crds_established argocd-crds
}

# argocd: the Argo CD smoke check.  Wait on exactly the workloads the chart
# renders with pods: the application-controller StatefulSet (a StatefulSet,
# not a Deployment, so a `wait deployment --all` would miss it) and the
# redis, repo-server, and server Deployments.  Deliberately not waited on:
# the applicationset-controller Deployment renders with replicas: 0 (chart
# 9.x has no enabled toggle — see components/argocd/controller/buildplan.cue),
# so its rollout is trivially complete, and dex and notifications are
# disabled and render no workloads.  The redis-secret-init Job needs no
# gate of its own: pods consuming the argocd-redis Secret it creates wait
# in CreateContainerConfigError until it completes, which takes seconds —
# well inside the redis rollout's budget (contrast wait_quay, whose Job
# gate names the actual culprit ahead of a 900s rollout wait).  The
# argocd-initial-admin-secret is created by the server itself during its
# first startup, not by the chart, so nothing gates on its existence.
# Route attachment is level-triggered; verify the traffic path separately
# (see holos/README.md).
wait_argocd() {
  kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
    rollout status deployment/argocd-redis --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
    rollout status deployment/argocd-repo-server --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
    rollout status deployment/argocd-server --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
    rollout status statefulset/argocd-application-controller --timeout="${ROLLOUT_TIMEOUT}"
}

# kargo-crds: the Kargo controller and webhooks servers require the
# kargo.akuity.io types at startup, and the next phase (HOL-1240) applies
# Project/Warehouse/Stage custom resources.
wait_kargo_crds() {
  wait_crds_established kargo-crds
}

# kargo: the Kargo smoke check.  Wait on the workloads the chart renders with
# pods given this component's values: the controller and the API/UI Deployments,
# plus the internal and external webhooks servers and the management controller.
# Deliberately not waited on: dex (api.oidc.dex.enabled: false renders no pods)
# and the garbage collector (a CronJob, not a long-running Deployment).  The
# first reconcile pulls the multi-arch ghcr.io/akuity/kargo image, which may be
# slow — ROLLOUT_TIMEOUT covers it.  The internal webhooks server's TLS cert is
# issued by cert-manager (the chart's self-signed Issuer/Certificate), so this
# gate also confirms the cert-manager webhook admitted those resources.  Route
# attachment is level-triggered; verify the kargo.holos.localhost traffic path
# separately (see holos/README.md).
wait_kargo() {
  kubectl --context "${KUBE_CONTEXT}" --namespace kargo \
    rollout status deployment/kargo-controller --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace kargo \
    rollout status deployment/kargo-api --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace kargo \
    rollout status deployment/kargo-management-controller --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace kargo \
    rollout status deployment/kargo-webhooks-server --timeout="${ROLLOUT_TIMEOUT}"
  kubectl --context "${KUBE_CONTEXT}" --namespace kargo \
    rollout status deployment/kargo-external-webhooks-server --timeout="${ROLLOUT_TIMEOUT}"
}

# kargo-project-echo: gate on the Kargo Project reconciling before the kargo-echo
# Warehouse/Stage apply into its namespace.  The Project (cluster-scoped in Kargo
# 1.10) adopts the pre-created kargo-echo namespace (created by the namespaces
# component, carrying the kargo.akuity.io/project: "true" adoption label) and
# reports Ready; only then does the namespace carry Kargo's project RBAC so
# namespaced Warehouse/Stage resources apply cleanly.  Poll the Project's Ready
# condition (rather than `kubectl wait`) so a Stalled Project — e.g. the adoption
# label missing — fails the gate promptly with a clear pointer instead of
# blocking the full timeout.
wait_kargo_project_echo() {
  local project="project.kargo.akuity.io/kargo-echo" state lookup_failures=0
  local deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
  while true; do
    # Project is cluster-scoped (no --namespace).
    if state=$(kubectl --context "${KUBE_CONTEXT}" \
      get "${project}" --ignore-not-found --request-timeout=10s \
      -o jsonpath='{.metadata.name}{"\n"}{range .status.conditions[*]}{.type}={.status}{"\n"}{end}'); then
      lookup_failures=0
      if grep -q '^Ready=True$' <<<"${state}"; then
        break
      fi
      if grep -q '^Stalled=True$' <<<"${state}"; then
        echo "ERROR: ${project} is Stalled (often the kargo-echo namespace is missing the" >&2
        echo "       kargo.akuity.io/project: \"true\" adoption label); inspect it with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace kargo-echo describe ${project}" >&2
        return 1
      fi
    else
      lookup_failures=$((lookup_failures + 1))
      if [[ "${lookup_failures}" -ge 3 ]]; then
        echo "ERROR: repeated failures reading ${project}; aborting the gate." >&2
        return 1
      fi
    fi
    if [[ "${SECONDS}" -ge "${deadline}" ]]; then
      echo "ERROR: timed out waiting for ${project} to become Ready." >&2
      return 1
    fi
    sleep 5
  done
}

# kargo-echo: confirm the Warehouse, Stage, and target Argo CD Application
# applied and exist.  This is a structural smoke check, not a full pipeline run:
# the Warehouse cannot produce Freight until scripts/publish pushes an artifact,
# and the Application stays Unknown until the first promotion sets its
# targetRevision (deliberately uncommitted — Kargo owns the field) — both are
# exercised by the manual verification in holos/docs/oci-publish-workflow.md, not
# at apply time.
wait_kargo_echo() {
  kubectl --context "${KUBE_CONTEXT}" --namespace kargo-echo \
    get warehouse.kargo.akuity.io/manifests --request-timeout=10s >/dev/null
  kubectl --context "${KUBE_CONTEXT}" --namespace kargo-echo \
    get stage.kargo.akuity.io/test --request-timeout=10s >/dev/null
  kubectl --context "${KUBE_CONTEXT}" --namespace argocd \
    get application.argoproj.io/echo --request-timeout=10s >/dev/null
}

# my-project: delete the prior bootstrap Jobs before the apply.  Their names are
# constant (no config hash), so a completed Job is never re-run by a server-side
# apply of the unchanged spec; recreating them on every apply re-runs the
# idempotent generate/provision (each exits 0 leaving existing state untouched)
# and lets wait_my_project gate a genuinely fresh run.  --cascade=foreground
# --wait reaps the old Jobs' pods first so the new Jobs are the only ones
# wait_my_project can match.  Mirrors pre_keycloak_config.
#
# Two Jobs, two namespaces:
#   - my-project-quay-webhook-bootstrap (my-project ns) generates the Kargo
#     webhook receiver Secret's token (HOL-1270).
#   - my-project-quay-bootstrap (quay ns, HOL-1272) provisions the Quay org,
#     repo, pull robot, the Argo CD repository Secret, and the repo_push webhook.
#     It runs in the quay namespace because the admin OAuth token lives there.
#
# It also pre-applies the component's ServiceAccounts and their RBAC (Roles +
# RoleBindings) ahead of the main component apply (HOL-1275).  The main apply is
# `kubectl apply -f <dir>/`, which processes the rendered files in filename order
# — and `job-my-project-quay-bootstrap.yaml` sorts before
# `serviceaccount-my-project-quay-bootstrap.yaml`, so the Job is created before
# its ServiceAccount exists.  The Job controller then immediately tries to create
# a pod and fails with `error looking up service account
# quay/my-project-quay-bootstrap: serviceaccount "my-project-quay-bootstrap" not
# found`.  Applying the ServiceAccounts and RBAC here first guarantees they exist
# before the Job is created, so that race never happens.  Server-side apply is
# convergent, so the main apply re-applying these same objects is a no-op.
pre_my_project() {
  # Pre-apply ServiceAccounts + RBAC before the Jobs (see comment above).  The
  # shell expands each glob to the matching rendered files; the `[[ -e ]]` guard
  # drops a non-matching pattern (nullglob is not set) so a missing kind is not
  # passed to kubectl as a literal path.
  local dir="${COMPONENTS_DIR}/my-project"
  local rbac_files=() f
  for f in "${dir}"/serviceaccount-*.yaml "${dir}"/role-*.yaml "${dir}"/rolebinding-*.yaml; do
    [[ -e "${f}" ]] && rbac_files+=(-f "${f}")
  done
  if ((${#rbac_files[@]})); then
    kubectl --context "${KUBE_CONTEXT}" apply --server-side --force-conflicts \
      "${rbac_files[@]}"
  fi

  kubectl --context "${KUBE_CONTEXT}" --namespace my-project \
    delete job -l app.kubernetes.io/name=my-project-quay-webhook-bootstrap \
    --ignore-not-found --cascade=foreground --wait --request-timeout=60s
  kubectl --context "${KUBE_CONTEXT}" --namespace quay \
    delete job -l app.kubernetes.io/name=my-project-quay-bootstrap \
    --ignore-not-found --cascade=foreground --wait --request-timeout=60s
}

# my-project: gate the webhook-token bootstrap Job's completion, the Kargo
# Project's adoption of the my-project namespace, and the Quay-provisioning Job's
# completion (HOL-1272).
#
# The bootstrap Job generates the my-project-quay-webhook receiver Secret's token
# once; phase 4's Quay bootstrap reads that token to register the webhook, so a
# Failed bootstrap must surface here by name rather than as a missing-Secret error
# two phases later.  pre_my_project recreates the Job on every apply, so it is
# present; polled (not `kubectl wait --for=condition=Complete`) so a Failed Job
# fails the gate on the next poll instead of blocking the full timeout, and
# --ignore-not-found tolerates a TTL-GC'd Job (the Secret it created survives).
# This mirrors the wait_keycloak_config bootstrap-gate shape.
#
# The Project (cluster-scoped in Kargo 1.10) adopts the pre-created my-project
# namespace (created by the namespaces component, carrying the
# kargo.akuity.io/project: "true" adoption label) and reports Ready; only then
# does the namespace carry Kargo's project RBAC so the namespaced ProjectConfig,
# Warehouse, and Stage reconcile.  Poll the Ready condition (mirrors
# wait_kargo_project_echo) so a Stalled Project — e.g. the adoption label missing
# — fails promptly with a clear pointer.
# gate_job NAMESPACE JOB_NAME: poll a bootstrap Job to completion, returning 0
# when it reports Complete=True (or is already TTL-GC'd / absent — the state it
# created survives the Job, so a missing Job is success), and 1 when it reports
# Failed=True, times out, or cannot be queried repeatedly.  Polled rather than
# `kubectl wait --for=condition=Complete` so a Failed Job fails the gate on the
# next poll instead of blocking the full timeout.  Both my-project bootstrap Jobs
# share this shape (the webhook-token Job in my-project, the Quay-provisioning Job
# in quay), so the poll lives here once.
gate_job() {
  local namespace="$1" job="job/$2"
  local job_state lookup_failures=0
  local deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
  while true; do
    if job_state=$(kubectl --context "${KUBE_CONTEXT}" --namespace "${namespace}" \
      get "${job}" --ignore-not-found --request-timeout=10s \
      -o jsonpath='{.metadata.name}{"\n"}{range .status.conditions[*]}{.type}={.status}{"\n"}{end}'); then
      lookup_failures=0
      if [[ -z "${job_state}" ]] || grep -q '^Complete=True$' <<<"${job_state}"; then
        break
      fi
      if grep -q '^Failed=True$' <<<"${job_state}"; then
        echo "ERROR: ${namespace}/${job} failed; inspect it with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace ${namespace} describe ${job}" >&2
        return 1
      fi
    else
      lookup_failures=$((lookup_failures + 1))
      if ((lookup_failures >= 3)); then
        echo "ERROR: cannot query ${namespace}/${job}: ${lookup_failures} consecutive lookup failures." >&2
        return 1
      fi
    fi
    if ((SECONDS >= deadline)); then
      echo "ERROR: timed out after ${ROLLOUT_TIMEOUT} waiting for ${namespace}/${job} to complete." >&2
      return 1
    fi
    sleep 5
  done
}

wait_my_project() {
  # The webhook-token Job (my-project ns) generates the receiver Secret's token;
  # phase 4's Quay Job reads it, so surface a Failed bootstrap here by name rather
  # than as a missing-Secret error two phases later.
  gate_job my-project my-project-quay-webhook-bootstrap || return 1

  local project="project.kargo.akuity.io/my-project" state proj_lookup_failures=0
  local proj_deadline=$((SECONDS + ROLLOUT_TIMEOUT_SECONDS))
  while true; do
    # Project is cluster-scoped (no --namespace).
    if state=$(kubectl --context "${KUBE_CONTEXT}" \
      get "${project}" --ignore-not-found --request-timeout=10s \
      -o jsonpath='{.metadata.name}{"\n"}{range .status.conditions[*]}{.type}={.status}{"\n"}{end}'); then
      proj_lookup_failures=0
      if grep -q '^Ready=True$' <<<"${state}"; then
        break
      fi
      if grep -q '^Stalled=True$' <<<"${state}"; then
        echo "ERROR: ${project} is Stalled (often the my-project namespace is missing the" >&2
        echo "       kargo.akuity.io/project: \"true\" adoption label); inspect it with:" >&2
        echo "       kubectl --context ${KUBE_CONTEXT} --namespace my-project describe ${project}" >&2
        return 1
      fi
    else
      proj_lookup_failures=$((proj_lookup_failures + 1))
      if ((proj_lookup_failures >= 3)); then
        echo "ERROR: repeated failures reading ${project}; aborting the gate." >&2
        return 1
      fi
    fi
    if ((SECONDS >= proj_deadline)); then
      echo "ERROR: timed out waiting for ${project} to become Ready." >&2
      return 1
    fi
    sleep 5
  done

  # The Quay-provisioning Job (quay ns, HOL-1272) runs last: it depends on the
  # Project being Ready (so the namespaced ProjectConfig reconciles and Kargo
  # populates status.webhookReceivers[].url, which the Job reads to register the
  # webhook) and on the webhook-token Secret existing.  Gate its completion so a
  # failed Quay provisioning (missing org/repo/robot/webhook, or an unpopulated
  # receiver URL) surfaces here rather than as a silently broken delivery loop.
  gate_job quay my-project-quay-bootstrap || return 1
}

if ! command -v kubectl >/dev/null 2>&1; then
  echo "ERROR: 'kubectl' not found on PATH." >&2
  exit 1
fi
if [[ ! -d "${COMPONENTS_DIR}" ]]; then
  echo "ERROR: rendered manifests not found: ${COMPONENTS_DIR}" >&2
  echo "       The deploy tree is committed; is this a complete checkout?" >&2
  exit 1
fi

# Resolve and pin the target context before mutating anything: the manifests
# are rendered for the k3d-holos cluster, and a server-side apply with
# --force-conflicts seizes field ownership — refuse to do that to whatever
# context happens to be current unless it is k3d-holos or the operator
# explicitly opted in via KUBE_CONTEXT.  Every kubectl call below passes
# --context so a context switch in another terminal mid-run cannot redirect
# later components to a different cluster.
if [[ -z "${KUBE_CONTEXT:-}" ]]; then
  KUBE_CONTEXT="$(kubectl config current-context)"
  if [[ "${KUBE_CONTEXT}" != "k3d-holos" ]]; then
    echo "ERROR: current kubectl context is '${KUBE_CONTEXT}', expected 'k3d-holos'." >&2
    echo "       The rendered manifests target the k3d-holos cluster.  Set" >&2
    echo "       KUBE_CONTEXT explicitly to apply to a different context." >&2
    exit 1
  fi
fi
echo "Will apply manifests to kubectl context: ${KUBE_CONTEXT}"

if ! kubectl --context "${KUBE_CONTEXT}" version --request-timeout=10s >/dev/null 2>&1; then
  echo "ERROR: cannot reach the cluster for kubectl context '${KUBE_CONTEXT}'." >&2
  echo "       Create the local cluster with scripts/local-k3d (see docs/local-cluster.md)." >&2
  exit 1
fi

# Migration cleanup (HOL-1241): the NATS event-driven deployment pipeline (the
# nats backbone plus the webhook-receiver and webhook-subscriber components) was
# retired in favor of Kargo + the client-side ORAS publish workflow (ADR-16).
# This script applies only the component directories that still render, but a
# plain server-side apply never prunes resources whose manifests were removed
# from the deploy tree — so a cluster that previously applied the pipeline would
# keep its StatefulSet, Deployments, Services, HTTPRoutes, and the unauthenticated
# hooks.holos.localhost / nats.holos.localhost surfaces running indefinitely.
# Every resource the pipeline created lived entirely inside one of these three
# dedicated namespaces, so deleting the namespaces removes the workloads,
# routes, and policies in one cascade; the Gateway listeners they attached to
# are level-triggered and detach on their own.  --ignore-not-found makes this a
# no-op on a fresh cluster or after the first cleaned apply, keeping the script
# idempotent.  --wait=false returns immediately: namespace termination drains
# pods in the background and nothing applied later depends on these namespaces
# being gone.
echo "==> cleanup: retired NATS pipeline namespaces (HOL-1241)"
kubectl --context "${KUBE_CONTEXT}" delete namespace \
  nats webhook-receiver webhook-subscriber \
  --ignore-not-found --wait=false

for component in "${COMPONENTS[@]}"; do
  echo "==> ${component}"
  # Optional pre-apply hook, run before the component's manifests apply (the
  # mirror of the wait_<name> post-apply hook below).  Components without one
  # simply define no function.  Used where an apply alone cannot guarantee the
  # intended action — e.g. keycloak-config deletes its prior Job so every apply
  # runs a fresh reconcile (a completed Job is otherwise never re-run).
  pre_hook="pre_${component//-/_}"
  if declare -F "${pre_hook}" >/dev/null; then
    "${pre_hook}"
  fi
  attempts="$(apply_attempts "${component}")"
  for ((attempt = 1; ; attempt++)); do
    if kubectl --context "${KUBE_CONTEXT}" apply --server-side --force-conflicts \
      -f "${COMPONENTS_DIR}/${component}/"; then
      break
    fi
    if ((attempt >= attempts)); then
      echo "ERROR: apply failed for component '${component}'." >&2
      exit 1
    fi
    echo "    apply failed (may be the transient webhook x509 window); retrying in 5s (attempt ${attempt}/${attempts})..."
    sleep 5
  done
  wait_hook="wait_${component//-/_}"
  if declare -F "${wait_hook}" >/dev/null; then
    "${wait_hook}"
  fi
done

echo "All platform components applied."
